{
  "name": "AuditLog",
  "type": "object",
  "properties": {
    "log_id": {
      "type": "string",
      "description": "Unique audit log identifier"
    },
    "action_type": {
      "type": "string",
      "description": "Type of action: LOGIN, LOGOUT, PERMISSION_GRANT, PERMISSION_REVOKE, SUBSCRIPTION_CHANGE, PAGE_VISIBILITY_CHANGE, USER_CREATED, USER_DELETED, DATA_EXPORT, DATA_IMPORT, SETTINGS_CHANGE"
    },
    "performed_by": {
      "type": "string",
      "description": "User ID who performed the action"
    },
    "performed_by_email": {
      "type": "string",
      "description": "Email of user who performed the action"
    },
    "target_user_id": {
      "type": "string",
      "description": "User ID affected by the action (if any)"
    },
    "target_entity": {
      "type": "string",
      "description": "Entity type affected (e.g. PagePermission, Subscription)"
    },
    "target_id": {
      "type": "string",
      "description": "ID of affected record"
    },
    "details": {
      "type": "string",
      "description": "JSON string with additional context"
    },
    "ip_address": {
      "type": "string",
      "description": "IP address of the request"
    },
    "user_agent": {
      "type": "string",
      "description": "Browser user agent"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp"
    }
  },
  "required": [
    "log_id",
    "action_type",
    "performed_by",
    "timestamp"
  ]
}