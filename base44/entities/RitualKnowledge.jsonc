{
  "name": "RitualKnowledge",
  "type": "object",
  "description": "Canonical store for Amal, Ritual, Spiritual Procedure, Exorcism, and Protection knowledge. GLOBAL KNOWLEDGE CONFLICT RESOLUTION RULE: When multiple verified manuscripts provide information for the same canonical record, every newly extracted field is classified as Complementary (auto-merge), Equivalent (normalize-merge), Context-Specific (store under condition), or Conflicting (preserve both as Multiple Verified Opinions). The system never loses verified information and never blindly merges conflicting statements. Marker records prevent reprocessing. ISOLATED \u2014 only routeManuscriptKnowledge and enrichRitualFromManuscript write to this entity.",
  "properties": {
    "knowledge_id": {
      "type": "string",
      "description": "Permanent unique identifier. Format: RK-<source_entry_id>-<seq> or RK-MARKER-<entry_id>."
    },
    "source_type": {
      "type": "string",
      "enum": [
        "amal",
        "ritual",
        "procedure",
        "exorcism",
        "protection",
        "instruction"
      ],
      "description": "Type of ritual knowledge"
    },
    "knowledge_category": {
      "type": "string",
      "enum": [
        "ritual_procedure",
        "spiritual_practice",
        "exorcism_method",
        "protection_method",
        "sequence_of_actions",
        "preparation_step",
        "closing_procedure",
        "opening_procedure"
      ],
      "description": "Category of ritual knowledge"
    },
    "knowledge_text_en": {
      "type": "string",
      "description": "English text \u2014 RESOLVED text containing complementary and equivalent knowledge merged via LLM. Empty for markers."
    },
    "knowledge_text_ml": {
      "type": "string",
      "description": "Malayalam translation. Appended from new sources. Empty for markers."
    },
    "knowledge_text_ar": {
      "type": "string",
      "description": "Original Arabic text verbatim. Appended from new sources. Empty for markers."
    },
    "content_hash": {
      "type": "string",
      "description": "SHA-256 hash for duplicate detection. Markers use no-ritual-<entry_id>."
    },
    "canonical_key": {
      "type": "string",
      "description": "Canonical key for field-level evolution. Format: 'source_type|knowledge_category'."
    },
    "is_marker": {
      "type": "boolean",
      "default": false,
      "description": "If true, no ritual knowledge found. Never displayed."
    },
    "materials_summary": {
      "type": "string",
      "description": "Lightweight materials summary. Appended from new sources."
    },
    "timing_reference": {
      "type": "string",
      "description": "Lightweight cross-module reference to Astro Clock timing. Appended."
    },
    "duration": {
      "type": "string",
      "description": "Ritual duration if specified. Appended from new sources."
    },
    "context_specific": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "condition": {
            "type": "string",
            "description": "The condition this knowledge is valid under (e.g., 'weekday:Thursday', 'sahath:8', 'intention:love', 'material:silver')"
          },
          "text_en": {
            "type": "string"
          },
          "text_ml": {
            "type": "string"
          },
          "text_ar": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "book_title": {
                  "type": "string"
                },
                "page_number": {
                  "type": "string"
                },
                "entry_id": {
                  "type": "string"
                }
              }
            },
            "default": []
          },
          "source_count": {
            "type": "integer",
            "default": 1
          }
        }
      },
      "default": [],
      "description": "GLOBAL CONFLICT RESOLUTION RULE: Context-specific knowledge valid only under certain conditions. Stored under its matching condition without affecting other conditions."
    },
    "conflicting_opinions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string",
            "description": "Which field/topic conflicts (e.g., 'timing', 'method', 'materials', 'duration')"
          },
          "opinion_text_en": {
            "type": "string"
          },
          "opinion_text_ml": {
            "type": "string"
          },
          "opinion_text_ar": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "book_title": {
                  "type": "string"
                },
                "page_number": {
                  "type": "string"
                },
                "entry_id": {
                  "type": "string"
                }
              }
            },
            "default": []
          },
          "source_count": {
            "type": "integer",
            "default": 1
          },
          "confidence": {
            "type": "string",
            "enum": [
              "HIGH",
              "MEDIUM",
              "LOW"
            ],
            "default": "MEDIUM"
          }
        }
      },
      "default": [],
      "description": "GLOBAL CONFLICT RESOLUTION RULE: Conflicting opinions from verified sources. Both statements preserved. Each attached to its supporting sources. Marked as 'Multiple Verified Opinions'. Future manuscripts can strengthen one opinion through additional supporting sources."
    },
    "conflict_flags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "GLOBAL CONFLICT RESOLUTION RULE: List of fields that have conflicting opinions ('Multiple Verified Opinions')."
    },
    "source_book_id": {
      "type": "string",
      "description": "FK to ManuscriptBook.book_id"
    },
    "source_book_title": {
      "type": "string",
      "description": "Denormalized book title"
    },
    "source_page_number": {
      "type": "string",
      "description": "Page number"
    },
    "source_entry_id": {
      "type": "string",
      "description": "FK to ManuscriptEntry.entry_id"
    },
    "is_verified": {
      "type": "boolean",
      "default": false,
      "description": "True if source entry was verified."
    },
    "supporting_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "book_title": {
            "type": "string"
          },
          "page_number": {
            "type": "string"
          },
          "entry_id": {
            "type": "string"
          }
        }
      },
      "default": [],
      "description": "Additional sources. Updated when duplicate or canonical match found."
    },
    "source_count": {
      "type": "integer",
      "default": 1,
      "description": "Total sources. 0 for markers."
    }
  },
  "required": [
    "knowledge_id",
    "source_type",
    "knowledge_category",
    "knowledge_text_en",
    "content_hash"
  ],
  "indexes": [
    {
      "name": "idx_knowledge_id",
      "fields": [
        "knowledge_id"
      ]
    },
    {
      "name": "idx_content_hash",
      "fields": [
        "content_hash"
      ]
    },
    {
      "name": "idx_canonical_key",
      "fields": [
        "canonical_key"
      ]
    },
    {
      "name": "idx_source_type",
      "fields": [
        "source_type"
      ]
    },
    {
      "name": "idx_is_marker",
      "fields": [
        "is_marker"
      ]
    },
    {
      "name": "idx_is_verified",
      "fields": [
        "is_verified"
      ]
    },
    {
      "name": "idx_source_book_id",
      "fields": [
        "source_book_id"
      ]
    },
    {
      "name": "idx_source_entry_id",
      "fields": [
        "source_entry_id"
      ]
    },
    {
      "name": "idx_source_type_category",
      "fields": [
        "source_type",
        "knowledge_category"
      ]
    },
    {
      "name": "idx_conflict_flags",
      "fields": [
        "conflict_flags"
      ]
    }
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}