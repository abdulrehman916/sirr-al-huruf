{
  "name": "ManuscriptEntry",
  "type": "object",
  "description": "Extracted knowledge entries from imported manuscripts. Each entry is auto-classified into a Sirr section (1-7) and grouped by topic. Never merges entries from different books \u2014 every entry retains its book_id and book_title. Designed for unlimited expansion. Linked to ManuscriptBook via book_id, to ManuscriptHeading via heading_id (dynamic manuscript structure tree), and to VerifiedArabic via verified_arabic_hash. Enterprise Duplicate Detection: entries are grouped into Methods via method_id. The first entry of a method is is_primary_method_entry=true. Duplicates are linked, not merged \u2014 every source is preserved. RULE 11: Every saved entry must include Source book, Page number, Confidence score, Verification status, Verification source, Verification date.",
  "properties": {
    "entry_id": {
      "type": "string",
      "description": "Permanent unique identifier for this extracted entry. Format: ME-<book_id>-<seq>"
    },
    "book_id": {
      "type": "string",
      "description": "FK to ManuscriptBook.book_id. The manuscript this entry was extracted from. Never changes."
    },
    "book_title": {
      "type": "string",
      "description": "Denormalized book title for display without joins. SIRR LANGUAGE RULE: Book titles remain in their original language (Turkish/Arabic/English). Never translated."
    },
    "book_title_ar": {
      "type": "string",
      "description": "Denormalized Arabic book title for display. Original language preserved."
    },
    "sirr_section": {
      "type": "integer",
      "enum": [
        1,
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "description": "ALTERNATIVE CLASSIFICATION \u2014 not the primary navigation structure. Auto-classified Sirr section: 1=Diseases & Healing, 2=Jinn/Ruqyah, 3=Mahabbah, 4=Wafq/Taweez, 5=Duas/Quran, 6=Herbs/Incense, 7=Planetary/Times. The primary structure is the ManuscriptHeading tree (heading_id)."
    },
    "topic": {
      "type": "string",
      "description": "ALTERNATIVE classification topic name (English). The primary grouping is via heading_id (manuscript's own headings). This field is kept for backward compatibility and Sirr section filtering."
    },
    "topic_ml": {
      "type": "string",
      "description": "Malayalam topic name"
    },
    "topic_ar": {
      "type": "string",
      "description": "Arabic topic name (if available)"
    },
    "entry_type": {
      "type": "string",
      "enum": [
        "ritual",
        "dua",
        "quran_verse",
        "divine_name",
        "wafq",
        "taweez",
        "diagram",
        "image",
        "table",
        "instruction",
        "material",
        "timing",
        "condition",
        "warning",
        "note",
        "reference",
        "exorcism",
        "protection",
        "incense",
        "herb"
      ],
      "description": "Type of extracted content"
    },
    "purpose": {
      "type": "string",
      "description": "Purpose or goal of this entry (English)"
    },
    "purpose_ml": {
      "type": "string",
      "description": "Malayalam purpose"
    },
    "introduction": {
      "type": "string",
      "description": "Introduction or context (English)"
    },
    "arabic_text": {
      "type": "string",
      "description": "Original Arabic text, verbatim from the manuscript. Never AI-generated. Never modified."
    },
    "malayalam_meaning": {
      "type": "string",
      "description": "Malayalam translation of the Arabic text"
    },
    "english_meaning": {
      "type": "string",
      "description": "English translation of the Arabic text"
    },
    "conditions": {
      "type": "string",
      "description": "Conditions or prerequisites for performing this method (English)"
    },
    "materials": {
      "type": "string",
      "description": "Materials required (English)"
    },
    "preparation": {
      "type": "string",
      "description": "Preparation instructions (English)"
    },
    "procedure": {
      "type": "string",
      "description": "Procedure steps (English)"
    },
    "timing": {
      "type": "string",
      "description": "Timing requirements (planetary hour, time of day, etc.) (English)"
    },
    "planet": {
      "type": "string",
      "description": "Associated planet (English)"
    },
    "day": {
      "type": "string",
      "description": "Suitable day of the week (English)"
    },
    "incense": {
      "type": "string",
      "description": "Required incense (English)"
    },
    "repetition": {
      "type": "string",
      "description": "Repetition count (English)"
    },
    "warnings": {
      "type": "string",
      "description": "Warnings or precautions (English)"
    },
    "benefits": {
      "type": "string",
      "description": "Benefits or expected results (English)"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes from the manuscript (English)"
    },
    "content_translations_ml": {
      "type": "object",
      "additionalProperties": true,
      "default": {},
      "description": "SIRR LANGUAGE RULE. Malayalam translations for content fields that do NOT have a dedicated _ml variant (introduction, conditions, materials, preparation, procedure, timing, planet, day, incense, repetition, warnings, benefits, notes). Keys are field names, values are Malayalam translations. Populated by translateSirrTurkishFields. Used by sirrTurkishGuard to display 100% Malayalam content when Malayalam is selected. Never contains Turkish or English."
    },
    "page_number": {
      "type": "string",
      "description": "Page number in the source PDF"
    },
    "heading_id": {
      "type": "string",
      "description": "FK to ManuscriptHeading.heading_id. The manuscript heading this entry belongs to (chapter/section/subsection \u2014 dynamic tree, any depth). Empty for entries from books imported before the heading tree system. The 7 Sirr sections remain as an alternative classification, not the primary navigation."
    },
    "entry_order": {
      "type": "integer",
      "description": "Sequential position of this entry within the book, by page order. Preserves the exact manuscript page-by-page ordering. 1-based."
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Extracted image URLs (diagrams, wafq, taweez, seals). Original images only \u2014 never redrawn or AI-recreated."
    },
    "verified_arabic_hash": {
      "type": "string",
      "description": "text_hash linking to VerifiedArabic entity for verified harakat. Empty if not yet verified. Used in Stage 1 duplicate detection (exact Arabic match)."
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "unverified",
        "pending",
        "verified",
        "manual_review"
      ],
      "default": "unverified",
      "description": "Arabic verification status"
    },
    "verification_source": {
      "type": "string",
      "description": "RULE 11: Primary source used for Arabic verification (denormalized from VerifiedArabic.primary_source for display without joins). Empty if not yet verified."
    },
    "verification_date": {
      "type": "string",
      "description": "RULE 11: ISO 8601 date when this entry's Arabic was verified. Empty if not yet verified."
    },
    "extraction_confidence": {
      "type": "number",
      "description": "AI extraction confidence score (0-100)"
    },
    "extraction_date": {
      "type": "string",
      "description": "ISO 8601 date when this entry was extracted"
    },
    "method_id": {
      "type": "string",
      "description": "ENTERPRISE DUPLICATE DETECTION. Unique method group identifier. All entries describing the same method share this ID. The first entry (primary) generates it as METHOD-<timestamp>-<rand>. Duplicates inherit the primary's method_id. Used to group sources under one method."
    },
    "is_primary_method_entry": {
      "type": "boolean",
      "default": true,
      "description": "True for the PRIMARY entry of a method (the first one found). False for duplicate entries linked to this method. Only primary entries are comparison targets for new entries."
    },
    "linked_method_id": {
      "type": "string",
      "description": "For duplicate entries (is_primary_method_entry=false): the entry_id of the PRIMARY method entry they are linked to. Empty for primary entries."
    },
    "duplicate_status": {
      "type": "string",
      "enum": [
        "pending_detection",
        "unique",
        "exact_duplicate",
        "same_method",
        "equivalent_method"
      ],
      "default": "pending_detection",
      "description": "Result of 3-stage duplicate detection. pending_detection=not yet processed. unique=no match found, new method created. exact_duplicate=Stage 1 match (normalized Arabic identical). same_method=Stage 2 match (all structure fields match). equivalent_method=Stage 3 match (semantically same ritual, no practical differences)."
    },
    "primary_source": {
      "type": "object",
      "additionalProperties": true,
      "description": "PRIMARY ENTRY ONLY. Source metadata for the primary source of this method: { book_title, author, page_number, pdf_url, edition, year }. Derived from this entry's own book metadata when the method is first created."
    },
    "supporting_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "book_title": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "page_number": {
            "type": "string"
          },
          "pdf_url": {
            "type": "string"
          },
          "edition": {
            "type": "string"
          },
          "year": {
            "type": "string"
          },
          "entry_id": {
            "type": "string"
          }
        }
      },
      "default": [],
      "description": "PRIMARY ENTRY ONLY. All additional sources that teach the same method. Each linked duplicate entry contributes one source object. Updated every time a new duplicate is linked."
    },
    "source_count": {
      "type": "integer",
      "default": 1,
      "description": "PRIMARY ENTRY ONLY. Total number of sources (books/pages) teaching this method. 1 = only the primary source. Incremented each time a duplicate is linked."
    },
    "confidence_score": {
      "type": "number",
      "description": "Duplicate detection confidence score (0-100). 100=exact Arabic match (Stage 1). 90=structure match (Stage 2). 70+=semantic match (Stage 3). 100 for unique entries (new method)."
    },
    "duplicate_detection_date": {
      "type": "string",
      "description": "ISO 8601 date when duplicate detection was run for this entry."
    }
  },
  "required": [
    "entry_id",
    "book_id",
    "sirr_section",
    "entry_type"
  ],
  "indexes": [
    {
      "name": "idx_entry_id",
      "fields": [
        "entry_id"
      ]
    },
    {
      "name": "idx_book_id",
      "fields": [
        "book_id"
      ]
    },
    {
      "name": "idx_sirr_section",
      "fields": [
        "sirr_section"
      ]
    },
    {
      "name": "idx_sirr_section_topic",
      "fields": [
        "sirr_section",
        "topic"
      ]
    },
    {
      "name": "idx_book_id_sirr_section",
      "fields": [
        "book_id",
        "sirr_section"
      ]
    },
    {
      "name": "idx_entry_type",
      "fields": [
        "entry_type"
      ]
    },
    {
      "name": "idx_verification_status",
      "fields": [
        "verification_status"
      ]
    },
    {
      "name": "idx_book_id_entry_type",
      "fields": [
        "book_id",
        "entry_type"
      ]
    },
    {
      "name": "idx_verified_arabic_hash",
      "fields": [
        "verified_arabic_hash"
      ]
    },
    {
      "name": "idx_method_id",
      "fields": [
        "method_id"
      ]
    },
    {
      "name": "idx_duplicate_status",
      "fields": [
        "duplicate_status"
      ]
    },
    {
      "name": "idx_is_primary_method",
      "fields": [
        "is_primary_method_entry"
      ]
    },
    {
      "name": "idx_sirr_section_primary",
      "fields": [
        "sirr_section",
        "is_primary_method_entry"
      ]
    },
    {
      "name": "idx_method_id_primary",
      "fields": [
        "method_id",
        "is_primary_method_entry"
      ]
    },
    {
      "name": "idx_heading_id",
      "fields": [
        "heading_id"
      ]
    },
    {
      "name": "idx_book_heading_order",
      "fields": [
        "book_id",
        "heading_id",
        "entry_order"
      ]
    },
    {
      "name": "idx_book_entry_order",
      "fields": [
        "book_id",
        "entry_order"
      ]
    }
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}