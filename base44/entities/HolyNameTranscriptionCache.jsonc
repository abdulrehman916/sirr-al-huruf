{
  "name": "HolyNameTranscriptionCache",
  "type": "object",
  "description": "PERMANENT one-time vision transcription cache for the Holy Names PDF. ONE record per PDF page. Idempotent: each page is transcribed by vision EXACTLY ONCE and never re-extracted, giving a single stable text representation of the entire book. The chapter-based importer (importHolyNamesByChapter, mode 'import_cached') reads ONLY from this cache and never re-runs vision, so the full import is fully DETERMINISTIC. TOC pages are flagged is_toc=true and excluded from chapter detection. ISOLATED \u2014 only extractHolyNamesPdfCache writes this entity; only importHolyNamesByChapter (cache mode) and verifyHolyNamesImport read it. No other module, engine, or page touches it. Designed for unlimited future books (keyed by source_pdf_file + page_number).",
  "properties": {
    "cache_id": {
      "type": "string",
      "description": "Permanent unique identifier: HNTC-<sha256(source_pdf_file)>-p<page_number>. Never changes."
    },
    "source_pdf_file": {
      "type": "string",
      "description": "Original file name of the source PDF. Groups all cached pages for one book."
    },
    "source_pdf_url": {
      "type": "string",
      "default": "",
      "description": "Permanent URL of the source PDF (from UploadFile)."
    },
    "page_number": {
      "type": "integer",
      "description": "1-based PDF physical page number. The page this cached text came from."
    },
    "page_text": {
      "type": "string",
      "description": "VERBATIM text of this page from the ONE-TIME vision transcription pass. Every Arabic letter, harakat, Qur'an verse, Hadith, paragraph, table entry, and line break preserved exactly as printed. Never re-extracted, never modified."
    },
    "is_toc": {
      "type": "boolean",
      "default": false,
      "description": "True if this page is part of the book's Table of Contents (excluded from chapter detection). Auto-detected: a page with >= 4 line-start '\u0627\u0633\u0645\u0647' heading lines is a TOC page (the TOC lists many names per page; content pages have 1-2). Can also be forced by the caller's toc_page_end override."
    },
    "has_ismeh_heading": {
      "type": "boolean",
      "default": false,
      "description": "True if this page contains at least one line-start '\u0627\u0633\u0645\u0647 X' chapter heading (a real chapter starts on this page)."
    },
    "ismeh_heading_count": {
      "type": "integer",
      "default": 0,
      "description": "Number of line-start '\u0627\u0633\u0645\u0647' heading lines on this page. Used for TOC detection (>=4 \u2192 TOC)."
    },
    "extracted_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of the one-time vision extraction for this page."
    },
    "extraction_method": {
      "type": "string",
      "default": "vision_once",
      "description": "Always 'vision_once' \u2014 the single deterministic extraction pass."
    },
    "char_count": {
      "type": "integer",
      "default": 0,
      "description": "Character count of page_text. For verification/coverage reporting."
    }
  },
  "required": [
    "cache_id",
    "source_pdf_file",
    "page_number",
    "page_text"
  ],
  "indexes": [
    {
      "name": "idx_cache_id",
      "fields": [
        "cache_id"
      ]
    },
    {
      "name": "idx_source_pdf_file",
      "fields": [
        "source_pdf_file"
      ]
    },
    {
      "name": "idx_page_number",
      "fields": [
        "page_number"
      ]
    },
    {
      "name": "idx_file_page",
      "fields": [
        "source_pdf_file",
        "page_number"
      ]
    },
    {
      "name": "idx_is_toc",
      "fields": [
        "is_toc"
      ]
    },
    {
      "name": "idx_file_toc_page",
      "fields": [
        "source_pdf_file",
        "is_toc",
        "page_number"
      ]
    },
    {
      "name": "idx_has_ismeh",
      "fields": [
        "has_ismeh_heading"
      ]
    }
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}