{
  "name": "SubscriptionPlanConfig",
  "type": "object",
  "properties": {
    "plan_config_id": {
      "type": "string",
      "description": "Unique plan ID e.g. PLAN-abjad_kabir-1"
    },
    "page_path": {
      "type": "string",
      "description": "Page route e.g. /abjad, /mizaan9"
    },
    "feature_id": {
      "type": "string",
      "description": "Feature ID e.g. abjad_kabir, method_1. Use 'FULL_PAGE' for page-level plans on non-multi-feature pages."
    },
    "plan_name": {
      "type": "string",
      "description": "Display name e.g. '1 Month', 'Lifetime'"
    },
    "duration_type": {
      "type": "string",
      "enum": [
        "DAYS",
        "MONTHS",
        "YEARS",
        "LIFETIME"
      ],
      "description": "Duration unit \u2014 DAYS, MONTHS, YEARS, or LIFETIME"
    },
    "duration_count": {
      "type": "integer",
      "description": "Count in the selected unit (e.g. 3 for 3 months). Null for LIFETIME."
    },
    "duration_days": {
      "type": "integer",
      "description": "Total computed days for expiry calculation (count * unit multiplier). Null for LIFETIME. This is the field used by the redemption logic."
    },
    "price": {
      "type": "number",
      "description": "Numeric price amount e.g. 25"
    },
    "currency": {
      "type": "string",
      "default": "AED",
      "description": "Currency code e.g. AED, USD"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "If false, this plan is hidden from locked screens and admin code creation"
    },
    "sort_order": {
      "type": "integer",
      "default": 0,
      "description": "Display sort order (lower = first)"
    },
    "updated_by": {
      "type": "string",
      "description": "Admin user ID who last updated"
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of last update"
    }
  },
  "required": [
    "plan_config_id",
    "page_path",
    "feature_id",
    "plan_name",
    "price"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}