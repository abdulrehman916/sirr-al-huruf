            "type": "string",
            "default": ""
          },
          "source_page": {
            "type": "string",
            "default": ""
          },
          "note": {
            "type": "string",
            "default": ""
          }
        },
        "required": [
          "meaning"
        ]
      },
      "default": [],
      "description": "Every alternate meaning attested by any source (distinct from the primary exact_meaning). Append-only."
    },
    "alternate_abjad_values": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "abjad": {
            "type": "integer"
          },
          "source_reference": {
            "type": "string",
            "default": ""
          },
          "source_page": {
            "type": "string",
            "default": ""
          },
          "note": {
            "type": "string",
            "default": ""
          }
        },
        "required": [
          "abjad"
        ]
      },
      "default": [],
      "description": "Every alternate Abjad value attested by any source (when a source differs from total_abjad_value). Append-only."
    },
