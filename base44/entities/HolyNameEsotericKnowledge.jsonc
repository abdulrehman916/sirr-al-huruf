{
  "name": "HolyNameEsotericKnowledge",
  "type": "object",
  "description": "INDEPENDENT Section C database \u2014 Barhatiyya / Esoteric Invocation Names (Ruhaniyyat, Shams al-Ma'arif, Khawass manuscripts, Syriac magical names, Hebrew-derived invocations, and other historical esoteric Islamic manuscripts). COMPLETELY SEPARATE from Section A (HolyNameKnowledge occult_section_a) and Section B (HolyOnePDFName). Each record is ONE independent card with a permanent unique ID (HNK-MHC-001, HNK-MHC-002, ...). AT THIS STAGE the database is STRUCTURE ONLY \u2014 every scholarly field is prepared but EMPTY; nothing is fabricated, guessed, inferred, or AI-generated. Future enrichment comes ONLY from PDFs/books/manuscripts/references the owner personally provides. The scholarly verification + enrichment pipeline (authoritative harakat, linguistic info, Islamic knowledge, traditional practices, research profile, separated meanings, source-supported benefits, relationship to 99 Names, invocations) is identical in structure to Section A so the same enrichment flow works. ISOLATED \u2014 only the Section C page, seedHolyNameEsoteric, and a future Section-C enrichment function read/write this entity. No other module, engine, or page touches it. TRILINGUAL (Arabic/English/Malayalam): every prose explanation field has a *_ml Malayalam counterpart, empty until enriched.",
  "properties": {
    "name_id": {
      "type": "string",
      "description": "Permanent unique identifier. Format: HNK-MHC-001, HNK-MHC-002, ... Sequential, never changes."
    },
    "arabic_name": {
      "type": "string",
      "description": "Arabic name as supplied by the owner (with harakat if provided). The display + future matching source. Starts as supplied; a future scholarly verification pass may correct it (spelling_corrected + spelling_correction) when documentary evidence proves the supplied form was an OCR/transcription error \u2014 the name's identity is always preserved."
    },
    "arabic_normalized": {
      "type": "string",
      "default": "",
      "description": "Arabic name WITHOUT harakat/tatweel, leading '\u0627\u0644' kept, normalized for indexed matching/search. Populated at seed time from arabic_name."
    },
    "transliteration": {
      "type": "string",
      "default": "",
      "description": "Latin transliteration of the name (reference only), as supplied."
    },
    "malayalam_name": {
      "type": "string",
      "default": "",
      "description": "Malayalam rendering of the name if found in a provided source. Empty until imported."
    },
    "meaning_en": {
      "type": "string",
      "default": "",
      "description": "English meaning (reference only). Empty until enriched from a provided source."
    },
    "order_index": {
      "type": "integer",
      "default": 0,
      "description": "Display order (sequential order as supplied)."
    },
    "section_count": {
      "type": "integer",
      "default": 0,
      "description": "Denormalized count of HolyNameImportedSection records (source_section='section_c') linked to this name. Updated by future import functions."
    },
    "last_imported_at": {
      "type": "string",
      "default": "",
      "description": "ISO 8601 timestamp of the most recent source import that added content to this name."
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Inactive names are excluded from matching and display."
    },
    "seeded": {
      "type": "boolean",
      "default": false,
      "description": "True if this name was seeded from an owner-supplied list (always true for Section C \u2014 these are not canonical 99-Name seed records). Kept for schema parity with Section A."
    },
    "original_static_id": {
      "type": "integer",
      "default": 0,
      "description": "Original 1-based position in the owner's supplied list, preserved permanently for traceability."
    },
    "abjad_value": {
      "type": "integer",
      "default": 0,
      "description": "Traditional occult Abjad value as supplied by the owner (preserved verbatim, never recalculated by the system)."
    },
    "letter_count": {
      "type": "integer",
      "default": 0,
      "description": "Letter count as supplied by the owner (preserved verbatim)."
    },
    "esoteric_source_ref": {
      "type": "string",
      "default": "",
      "description": "The esoteric source manuscript/reference this name comes from (e.g. 'Barhatiyya', 'Shams al-Ma'arif', 'Ruhaniyyat', 'Khawass manuscript'). As supplied by the owner."
    },
    "canonical_arabic": {
      "type": "string",
      "default": "",
      "description": "AUTHORITATIVE fully-vowelized canonical Arabic spelling, verified against authoritative sources for the name's actual linguistic origin. Empty until verified \u2014 NEVER guessed. When sources disagree, the preferred scholarly reading is stored here and variants go to alternative_readings. When the supplied arabic_name was a proven OCR/transcription error, this holds the corrected form (and arabic_name is also corrected to it)."
    },
    "fully_vowelized_name": {
      "type": "string",
      "default": "",
      "description": "Alias of canonical_arabic: the complete vowelized form with every harakah verified. Empty until verified."
    },
    "spelling_corrected": {
      "type": "boolean",
      "default": false,
      "description": "True if the supplied arabic_name spelling or harakat was corrected by a future scholarly verification pass because the supplied form was a proven OCR error or transcription mistake backed by documentary evidence."
    },
    "spelling_correction": {
      "type": "object",
      "properties": {
        "previous_spelling": {
          "type": "string",
          "default": ""
        },
        "corrected_spelling": {
          "type": "string",
          "default": ""
        },
        "previous_harakat": {
          "type": "string",
          "default": ""
        },
        "corrected_harakat": {
          "type": "string",
          "default": ""
        },
        "confidence": {
          "type": "integer",
          "default": 0
        },
        "evidence": {
          "type": "string",
          "default": ""
        },
        "corrected_at": {
          "type": "string",
          "default": ""
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "page": {
                "type": "string",
                "default": ""
              },
              "url": {
                "type": "string",
                "default": ""
              }
            }
          },
          "default": []
        }
      },
      "default": {},
      "description": "Full correction record when spelling_corrected=true. Empty object when no correction was needed."
    },
    "alternative_readings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "arabic": {
            "type": "string"
          },
          "reading_note": {
            "type": "string",
            "default": ""
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string"
                },
                "page": {
                  "type": "string",
                  "default": ""
                },
                "url": {
                  "type": "string",
                  "default": ""
                },
                "language": {
                  "type": "string",
                  "default": ""
                },
                "reliability_score": {
                  "type": "integer",
                  "default": 0
                }
              }
            },
            "default": []
          },
          "preferred": {
            "type": "boolean",
            "default": false
          }
        },
        "required": [
          "arabic"
        ]
      },
      "default": [],
      "description": "Every alternative VOCALIZATION/harakat reading attested by a source, with its source(s) and a preferred flag. Populated only when authoritative sources disagree \u2014 never auto-overwritten."
    },
    "alternative_spellings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "arabic": {
            "type": "string"
          },
          "note": {
            "type": "string",
            "default": ""
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string"
                },
                "page": {
                  "type": "string",
                  "default": ""
                },
                "url": {
                  "type": "string",
                  "default": ""
                }
              }
            },
            "default": []
          }
        },
        "required": [
          "arabic"
        ]
      },
      "default": [],
      "description": "Alternative SPELLINGS of the name. Each with source attribution. Append-only."
    },
    "original_source_word": {
      "type": "string",
      "default": "",
      "description": "The original word in its source language (Hebrew/Syriac/Aramaic/Persian/etc.) when the name is a transliteration of a foreign Divine/angelic name. Empty when origin is Arabic or unknown."
    },
    "harakat_verified": {
      "type": "boolean",
      "default": false,
      "description": "True only when every harakah, hamza, madd, shaddah, sukoon, tanween, and wasl/qat' has been confirmed by >=2 authoritative sources for the name's origin. False until then."
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "unverified",
        "verified",
        "needs_review",
        "conflicting_sources",
        "not_in_classical_sources"
      ],
      "default": "unverified",
      "description": "Harakat verification gate. 'unverified' = not yet audited (default for all Section C cards at creation). 'verified' = >=2 authoritative sources agree. 'needs_review' = insufficient or uncertain sources. 'conflicting_sources' = authoritative sources disagree. 'not_in_classical_sources' = name not found in any classical source of its origin."
    },
    "verification_confidence": {
      "type": "integer",
      "default": 0,
      "description": "Confidence score 0-100 for the harakat verification. 0 = not yet audited."
    },
    "verification_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "author": {
            "type": "string",
            "default": ""
          },
          "publisher": {
            "type": "string",
            "default": ""
          },
          "edition": {
            "type": "string",
            "default": ""
          },
          "page": {
            "type": "string",
            "default": ""
          },
          "volume": {
            "type": "string",
            "default": ""
          },
          "url": {
            "type": "string",
            "default": ""
          },
          "access_date": {
            "type": "string",
            "default": ""
          },
          "language": {
            "type": "string",
            "default": ""
          },
          "reliability_score": {
            "type": "integer",
            "default": 0
          },
          "field_verified": {
            "type": "string",
            "default": ""
          }
        },
        "required": [
          "title"
        ]
      },
      "default": [],
      "description": "Every source consulted for this name's verification, with full bibliographic attribution and a per-field note of what it verified. Append-only."
    },
    "last_verified_date": {
      "type": "string",
      "default": "",
      "description": "ISO 8601 date of the most recent authoritative harakat verification pass."
    },
    "name_origin": {
      "type": "string",
      "enum": [
        "hebrew",
        "syriac",
        "aramaic",
        "arabic",
        "persian",
        "mixed",
        "unknown"
      ],
      "default": "unknown",
      "description": "The name's actual linguistic origin, determined honestly per name during future enrichment. 'unknown' until audited (never guessed)."
    },
    "etymology": {
      "type": "string",
      "default": "",
      "description": "Honest etymological trace of the name to its source language and original form. Empty when origin is unknown \u2014 never fabricated."
    },
    "linguistic": {
      "type": "object",
      "additionalProperties": true,
      "default": {},
      "description": "Linguistic information object: { root_letters, arabic_root, morphological_pattern, literal_meaning, lexical_meaning, classical_explanation, quranic_usage, hadith_usage, difference_from_similar, related_names, grammar_notes, origin_language }. Filled ONLY from authoritative sources for the name's origin during future enrichment; empty until then."
    },
    "islamic_knowledge": {
      "type": "object",
      "additionalProperties": true,
      "default": {},
      "description": "Islamic knowledge object: { meaning, detailed_explanation, tafsir_refs, hadith_refs, scholarly_explanation, spiritual_significance, conditions_of_usage, authentic_duas, authentic_adhkar, quran_verses, classical_explanations, *_ml }. Filled ONLY when the name genuinely appears in Islamic sources; left empty (not fabricated) for foreign-origin names absent from the Qur'an/Hadith/classical scholarship."
    },
    "traditional_practices": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "wafq",
              "amal",
              "dua",
              "hizb",
              "dhikr",
              "other"
            ]
          },
          "text_ar": {
            "type": "string",
            "default": ""
          },
          "translation_en": {
            "type": "string",
            "default": ""
          },
          "translation_ml": {
            "type": "string",
            "default": ""
          },
          "source": {
            "type": "string",
            "default": ""
          },
          "authenticated": {
            "type": "boolean",
            "default": false
          },
          "note": {
            "type": "string",
            "default": ""
          }
        },
        "required": [
          "type"
        ]
      },
      "default": [],
      "description": "Traditional manuscript practices (wafq/amal/dua/hizb/dhikr) associated with this name, with COMPLETE source attribution. authenticated=false and note='Traditional Manuscript Reference (Not authenticated)' when authenticity cannot be verified \u2014 never presented as established Islamic fact."
    },
    "research_profile": {
      "type": "object",
      "additionalProperties": true,
      "default": {},
      "description": "DEEP RESEARCH PROFILE (future enrichment from provided sources only). Holds: { historical_background, pronunciation_guide, classical_dict_refs[], academic_refs[], manuscript_refs[], earliest_occurrence, related_historical_usage, linguistic_explanation, root_meaning, literal_meaning, root_letters, arabic_root, morphological_pattern, *_ml }. Each sub-field filled ONLY from reliable provided sources; left empty or 'Not Verified' when unsupported. Never fabricated."
    },
    "meanings": {
      "type": "object",
      "additionalProperties": true,
      "default": {},
      "description": "SEPARATED MEANINGS: { arabic, malayalam, english, original, symbolic, historical, traditional, *_ml }. symbolic ONLY when sourced. Empty until enriched from provided sources."
    },
    "benefits": {
      "type": "object",
      "additionalProperties": true,
      "default": {},
      "description": "SOURCE-SUPPORTED BENEFITS by category: { authentic_islamic[], linguistic[], historical[], traditional[], wafq[], amal[], esoteric[], *_ml }. Each entry: { text, sources[], authenticated }. Traditional/occult material labeled 'Traditional/Historical/Not Authenticated as Islamic Teaching' with authenticated=false. Empty until enriched."
    },
    "relationship_to_99_names": {
      "type": "object",
      "additionalProperties": true,
      "default": {},
      "description": "RELATIONSHIP to the canonical 99 Names of Allah. { relationship_type, related_name_id, related_name_arabic, evidence, sources[], *_ml }. relationship_type: identical | alternate_reading | same_root | same_meaning | closely_related | synonymous | scholarly_relation | none | foreign_equivalent | traditional_only. 'none' = no authentic relationship found. Empty until enriched."
    },
    "relationship_to_99_names_type": {
      "type": "string",
      "enum": [
        "identical",
        "alternate_reading",
        "same_root",
        "same_meaning",
        "closely_related",
        "synonymous",
        "scholarly_relation",
        "none",
        "foreign_equivalent",
        "traditional_only",
        "unknown"
      ],
      "default": "unknown",
      "description": "Denormalized relationship_type for indexed filtering. 'unknown' until audited."
    },
    "invocations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "authentic_islamic_dhikr",
              "quranic_supplication",
              "hadith_supplication",
              "classical_wazifa",
              "traditional_invocation",
              "vefk_practice",
              "talismanic_formula",
              "occult_manuscript_practice",
              "unknown_origin"
            ]
          },
          "text_ar": {
            "type": "string"
          },
          "text_harakat": {
            "type": "string",
            "default": ""
          },
          "transliteration": {
            "type": "string",
            "default": ""
          },
          "translation_ml": {
            "type": "string",
            "default": ""
          },
          "translation_en": {
            "type": "string",
            "default": ""
          },
          "source_book": {
            "type": "string",
            "default": ""
          },
          "author": {
            "type": "string",
            "default": ""
          },
          "chapter": {
            "type": "string",
            "default": ""
          },
          "page": {
            "type": "string",
            "default": ""
          },
          "edition": {
            "type": "string",
            "default": ""
          },
          "manuscript_ref": {
            "type": "string",
            "default": ""
          },
          "publication": {
            "type": "string",
            "default": ""
          },
          "url": {
            "type": "string",
            "default": ""
          },
          "purpose": {
            "type": "string",
            "default": ""
          },
          "traditional_usage": {
            "type": "string",
            "default": ""
          },
          "historical_usage": {
            "type": "string",
            "default": ""
          },
          "conditions": {
            "type": "string",
            "default": ""
          },
          "repetitions": {
            "type": "string",
            "default": ""
          },
          "timing": {
            "type": "string",
            "default": ""
          },
          "preparation": {
            "type": "string",
            "default": ""
          },
          "warnings": {
            "type": "string",
            "default": ""
          },
          "authenticated": {
            "type": "boolean",
            "default": false
          },
          "scholarly_opinions": {
            "type": "string",
            "default": ""
          },
          "evidence_level": {
            "type": "string",
            "enum": [
              "authenticated",
              "traditional",
              "unknown"
            ],
            "default": "unknown"
          }
        },
        "required": [
          "category",
          "text_ar"
        ]
      },
      "default": [],
      "description": "PRACTICES, INVOCATIONS & MANUSCRIPT TEXTS explicitly containing this Holy Name, collected ONLY from trusted historical sources the owner provides. NEVER fabricated \u2014 every Arabic letter and harakat copied exactly as printed in its source. Empty array until provided sources are imported."
    },
    "review_notes": {
      "type": "string",
      "default": "",
      "description": "Manual review notes for records flagged verification_status='needs_review' or 'conflicting_sources'."
    },
    "review_notes_ml": {
      "type": "string",
      "default": "",
      "description": "Natural Malayalam explanation of the review notes for Malayalam readers. Empty when review_notes is empty."
    }
  },
  "required": [
    "name_id",
    "arabic_name"
  ],
  "indexes": [
    {
      "name": "idx_name_id",
      "fields": [
        "name_id"
      ]
    },
    {
      "name": "idx_arabic_normalized",
      "fields": [
        "arabic_normalized"
      ]
    },
    {
      "name": "idx_is_active",
      "fields": [
        "is_active"
      ]
    },
    {
      "name": "idx_order_index",
      "fields": [
        "order_index"
      ]
    },
    {
      "name": "idx_seeded",
      "fields": [
        "seeded"
      ]
    },
    {
      "name": "idx_verification_status",
      "fields": [
        "verification_status"
      ]
    },
    {
      "name": "idx_name_origin",
      "fields": [
        "name_origin"
      ]
    },
    {
      "name": "idx_harakat_verified",
      "fields": [
        "harakat_verified"
      ]
    },
    {
      "name": "idx_original_static_id",
      "fields": [
        "original_static_id"
      ]
    },
    {
      "name": "idx_relationship_to_99_names_type",
      "fields": [
        "relationship_to_99_names_type"
      ]
    },
    {
      "name": "idx_spelling_corrected",
      "fields": [
        "spelling_corrected"
      ]
    },
    {
      "name": "idx_esoteric_source_ref",
      "fields": [
        "esoteric_source_ref"
      ]
    }
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}