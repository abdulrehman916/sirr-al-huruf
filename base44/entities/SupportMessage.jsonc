{
  "name": "SupportMessage",
  "type": "object",
  "properties": {
    "message_id": {
      "type": "string",
      "description": "Unique message ID e.g. MSG-000001"
    },
    "ticket_id": {
      "type": "string",
      "description": "FK to SupportTickets.ticket_id"
    },
    "sender_type": {
      "type": "string",
      "enum": [
        "CUSTOMER",
        "ADMIN"
      ],
      "description": "Who sent this message"
    },
    "sender_id": {
      "type": "string",
      "description": "User ID of sender (if admin) or customer email"
    },
    "sender_name": {
      "type": "string",
      "description": "Name of sender"
    },
    "message": {
      "type": "string",
      "description": "Message content"
    },
    "attachment_url": {
      "type": "string",
      "description": "Optional file attachment URL"
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 timestamp"
    },
    "is_read": {
      "type": "boolean",
      "default": false,
      "description": "Has recipient read this message?"
    }
  },
  "required": [
    "message_id",
    "ticket_id",
    "sender_type",
    "message",
    "created_at"
  ]
}