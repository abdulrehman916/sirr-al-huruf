{
  "name": "SubscriptionRequest",
  "type": "object",
  "properties": {
    "request_id": {
      "type": "string",
      "description": "Unique request ID e.g. SUBREQ-000001"
    },
    "user_id": {
      "type": "string",
      "description": "Base44 User ID (if logged in)"
    },
    "name": {
      "type": "string",
      "description": "Customer full name"
    },
    "mobile": {
      "type": "string",
      "description": "Customer mobile number"
    },
    "email": {
      "type": "string",
      "description": "Customer email address"
    },
    "selected_plan": {
      "type": "string",
      "enum": [
        "1_MONTH",
        "3_MONTHS",
        "6_MONTHS",
        "12_MONTHS",
        "CUSTOM"
      ],
      "description": "Requested subscription duration"
    },
    "custom_duration_months": {
      "type": "integer",
      "description": "If CUSTOM selected, number of months"
    },
    "page_path": {
      "type": "string",
      "description": "Page route requested e.g. /abjad, /vefkin-yapilisi"
    },
    "page_name": {
      "type": "string",
      "description": "Human-readable page name"
    },
    "message": {
      "type": "string",
      "description": "Customer message or reason for request"
    },
    "status": {
      "type": "string",
      "enum": [
        "PENDING",
        "APPROVED",
        "REJECTED",
        "ACTIVATED"
      ],
      "default": "PENDING",
      "description": "Request status"
    },
    "approved_by": {
      "type": "string",
      "description": "Admin user ID who approved"
    },
    "approved_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of approval"
    },
    "activation_duration_days": {
      "type": "integer",
      "description": "Number of days granted (calculated from plan)"
    },
    "expiry_date": {
      "type": "string",
      "description": "ISO 8601 timestamp - subscription expires"
    },
    "permission_id": {
      "type": "string",
      "description": "FK to PagePermission.permission_id (after activation)"
    },
    "requested_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of request"
    }
  },
  "required": [
    "request_id",
    "name",
    "mobile",
    "email",
    "selected_plan",
    "page_path",
    "page_name",
    "status",
    "requested_at"
  ]
}