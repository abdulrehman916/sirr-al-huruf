{
  "name": "HolyNameImportedSection",
  "type": "object",
  "description": "Child entity for the Holy Names PDF Knowledge Import System. ONE independent record per imported information block, linked to its HolyNameKnowledge name via name_id. Multiple PDFs can contribute multiple child records to the SAME Holy Name \u2014 they are never merged into one record; each stays independent. Every child record permanently remembers: source PDF file name, source PDF page number, the Holy Name it belongs to (name_id), the Original Arabic text (arabic_text \u2014 Arabic-script runs only), the Malayalam translation (malayalam_translation \u2014 Malayalam-script runs ONLY when the PDF actually prints Malayalam; EMPTY otherwise, never auto-generated), the Original book content (text_content \u2014 the full verbatim text exactly as printed, Arabic and Malayalam preserved), and the import date (import_date). Append-only: existing records are NEVER deleted or overwritten; duplicates are skipped by content_hash. ISOLATED \u2014 only importHolyNamesPDF writes this entity; only the Holy Names page PDF Knowledge tab reads it. No other module, engine, or page touches it.",
  "properties": {
    "section_id": {
      "type": "string",
      "description": "Permanent unique identifier, e.g. HNIS-<hash>. Never changes."
    },
    "name_id": {
      "type": "string",
      "description": "FK to HolyNameKnowledge.name_id. The Holy Name this child record belongs to. Many child records may share the same name_id (one per PDF page/section)."
    },
    "section_type": {
      "type": "string",
      "enum": [
        "arabic_name",
        "malayalam_meaning",
        "description",
        "benefits",
        "usage",
        "method",
        "warnings",
        "references",
        "notes",
        "other"
      ],
      "default": "other",
      "description": "Category of this information block. Raw extraction uses 'other' (cannot classify without LLM); the LLM fallback may assign a more specific type when the PDF clearly labels it. Defaults to 'other' when unknown \u2014 never guessed."
    },
    "text_content": {
      "type": "string",
      "description": "Original book content \u2014 the FULL VERBATIM text from the PDF, exactly as printed (Arabic and Malayalam preserved together if both appear on the page). Never rewritten, summarized, or regenerated. This is the faithful source of record."
    },
    "arabic_text": {
      "type": "string",
      "default": "",
      "description": "Original Arabic text \u2014 the Arabic-script portion of this section, extracted verbatim. Empty if the section has no Arabic script. Never auto-translated or generated."
    },
    "malayalam_translation": {
      "type": "string",
      "default": "",
      "description": "Malayalam translation printed in the PDF \u2014 the Malayalam-script portion of this section, extracted verbatim. EMPTY when the PDF does not contain Malayalam for this section. Never auto-generated or filled from another source."
    },
    "language": {
      "type": "string",
      "enum": [
        "ar",
        "ml",
        "en",
        "mixed"
      ],
      "default": "ar",
      "description": "Detected script of text_content: ar=Arabic, ml=Malayalam, en=English, mixed=both Arabic+Malayalam."
    },
    "source_pdf_file": {
      "type": "string",
      "default": "",
      "description": "Original file name of the source PDF this child record came from."
    },
    "source_pdf_url": {
      "type": "string",
      "default": "",
      "description": "Permanent URL of the source PDF (from UploadFile)."
    },
    "source_pdf_page": {
      "type": "integer",
      "default": 0,
      "description": "Page number in the source PDF where this section's text appears."
    },
    "import_date": {
      "type": "string",
      "default": "",
      "description": "ISO 8601 date when this child record was imported from the PDF."
    },
    "content_hash": {
      "type": "string",
      "description": "SHA-256 of (name_id + '|' + normalized text). Used to skip duplicate paragraphs on re-import \u2014 a record with the same hash already exists and is ignored, so identical content is never duplicated."
    },
    "import_batch": {
      "type": "string",
      "default": "",
      "description": "Import session identifier (HNK-<timestamp>) grouping all records from one upload action."
    }
  },
  "required": [
    "section_id",
    "name_id",
    "text_content",
    "content_hash"
  ],
  "indexes": [
    {
      "name": "idx_section_id",
      "fields": [
        "section_id"
      ]
    },
    {
      "name": "idx_name_id",
      "fields": [
        "name_id"
      ]
    },
    {
      "name": "idx_content_hash",
      "fields": [
        "content_hash"
      ]
    },
    {
      "name": "idx_name_hash",
      "fields": [
        "name_id",
        "content_hash"
      ]
    },
    {
      "name": "idx_name_page",
      "fields": [
        "name_id",
        "source_pdf_page"
      ]
    },
    {
      "name": "idx_name_file_page",
      "fields": [
        "name_id",
        "source_pdf_file",
        "source_pdf_page"
      ]
    },
    {
      "name": "idx_section_type",
      "fields": [
        "section_type"
      ]
    },
    {
      "name": "idx_import_batch",
      "fields": [
        "import_batch"
      ]
    },
    {
      "name": "idx_import_date",
      "fields": [
        "import_date"
      ]
    }
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}