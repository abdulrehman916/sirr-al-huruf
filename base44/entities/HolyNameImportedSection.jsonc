{
  "name": "HolyNameImportedSection",
  "type": "object",
  "description": "Child entity for the Holy Names PDF Knowledge Import System. ONE independent record per imported information block, linked to its Holy Name via source_section + source_name_key. source_section='section_a' links to the Section A static HOLY_NAMES array (source_name_key = String(name.id)); source_section='section_b' links to the HolyOnePDFName entity (source_name_key = pdf_name_id). Multiple PDFs can contribute multiple child records to the SAME Holy Name \u2014 they are never merged into one record; each stays independent. Every child record permanently remembers: source PDF file name, source PDF page number, the Holy Name it belongs to (source_section + source_name_key), the Original Arabic text (arabic_text \u2014 Arabic-script runs only), the Malayalam translation (malayalam_translation \u2014 Malayalam-script runs ONLY when the PDF actually prints Malayalam; EMPTY otherwise, never auto-generated), the Original book content (text_content \u2014 the full verbatim text exactly as printed, Arabic and Malayalam preserved), the import date (import_date), the auto-classified category (section_type \u2014 assigned by LLM classifier, NEVER modifies the verbatim text), and any visual content images (images \u2014 rendered page images for pages containing wafq/table/diagram/symbol/numeric content). Append-only: existing records are NEVER deleted or overwritten; duplicates are skipped by content_hash. ISOLATED \u2014 only importHolyNamesPDF writes this entity; only the Holy Names page (Section A cards + Section B detail page) reads it. No other module, engine, or page touches it. Designed for UNLIMITED future growth \u2014 the user uploads books little by little over months/years and the database keeps enriching the same Holy Names forever.",
  "properties": {
    "section_id": {
      "type": "string",
      "description": "Permanent unique identifier, e.g. HNIS-<hash>. Never changes."
    },
    "source_section": {
      "type": "string",
      "enum": [
        "section_a",
        "section_b"
      ],
      "default": "section_a",
      "description": "Which Holy Names section this child record enriches. 'section_a' = the static HOLY_NAMES array (source_name_key = String(name.id)); 'section_b' = the HolyOnePDFName entity (source_name_key = pdf_name_id)."
    },
    "source_name_key": {
      "type": "string",
      "description": "The key of the Holy Name within its section. For section_a: String(HOLY_NAMES id). For section_b: HolyOnePDFName.pdf_name_id. Multiple child records may share the same (source_section, source_name_key) \u2014 one per PDF page/section."
    },
    "name_id": {
      "type": "string",
      "description": "LEGACY compat alias of source_name_key. Kept so existing indexes keep working. Equals source_name_key. No longer a FK to HolyNameKnowledge."
    },
    "section_type": {
      "type": "string",
      "enum": [
        "arabic_name",
        "malayalam_meaning",
        "description",
        "benefits",
        "usage",
        "method",
        "recitations",
        "conditions",
        "warnings",
        "related_duas",
        "references",
        "notes",
        "wafq_diagram",
        "table",
        "symbol",
        "numeric_layout",
        "other"
      ],
      "default": "other",
      "description": "Auto-classified category of this information block. Assigned by the LLM CLASSIFIER ONLY \u2014 the LLM NEVER modifies, translates, or generates the verbatim text; it only reads it and returns a single category label. 'arabic_name' = the Holy Name itself in Arabic. 'malayalam_meaning' = Malayalam translation printed in the PDF. 'description' = general explanation. 'benefits' = spiritual/physical benefits. 'usage' = how to use. 'method' = procedure/practice. 'recitations' = repetition count/number. 'conditions' = prerequisites. 'warnings' = cautions. 'related_duas' = associated prayers. 'references' = citations. 'notes' = miscellaneous. 'wafq_diagram' = magic square / wafq. 'table' = tabular data. 'symbol' = symbolic content. 'numeric_layout' = number arrangement. 'other' = cannot classify. Defaults to 'other' when the classifier is unavailable or uncertain \u2014 never guessed."
    },
    "text_content": {
      "type": "string",
      "description": "Original book content \u2014 the FULL VERBATIM text from the PDF, exactly as printed (Arabic and Malayalam preserved together if both appear on the page). Never rewritten, summarized, or regenerated. This is the faithful source of record."
    },
    "arabic_text": {
      "type": "string",
      "default": "",
      "description": "Original Arabic text \u2014 the Arabic-script portion of this section, extracted verbatim. Empty if the section has no Arabic script. Never auto-translated or generated."
    },
    "malayalam_translation": {
      "type": "string",
      "default": "",
      "description": "Malayalam translation printed in the PDF \u2014 the Malayalam-script portion of this section, extracted verbatim. EMPTY when the PDF does not contain Malayalam for this section. Never auto-generated or filled from another source."
    },
    "language": {
      "type": "string",
      "enum": [
        "ar",
        "ml",
        "en",
        "mixed"
      ],
      "default": "ar",
      "description": "Detected script of text_content: ar=Arabic, ml=Malayalam, en=English, mixed=both Arabic+Malayalam."
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Rendered page image URLs for pages containing visual content (wafq/magic square, table, diagram, symbol, numeric layout, special drawing). The full PDF page is rendered to a canvas image, uploaded, and the URL stored here so the visual content is permanently preserved alongside the correct Holy Name. Empty for text-only pages."
    },
    "has_visual": {
      "type": "boolean",
      "default": false,
      "description": "True if this section's source page contains visual content (wafq, table, diagram, symbol, numeric layout). The images array is populated when this is true."
    },
    "source_pdf_file": {
      "type": "string",
      "default": "",
      "description": "Original file name of the source PDF this child record came from."
    },
    "source_pdf_url": {
      "type": "string",
      "default": "",
      "description": "Permanent URL of the source PDF (from UploadFile)."
    },
    "source_pdf_page": {
      "type": "integer",
      "default": 0,
      "description": "Page number in the source PDF where this section's text appears."
    },
    "import_date": {
      "type": "string",
      "default": "",
      "description": "ISO 8601 date when this child record was imported from the PDF."
    },
    "content_hash": {
      "type": "string",
      "description": "SHA-256 of (source_section + '|' + source_name_key + '|' + normalized text). Used to skip duplicate paragraphs on re-import \u2014 a record with the same hash already exists and is ignored, so identical content is never duplicated."
    },
    "import_batch": {
      "type": "string",
      "default": "",
      "description": "Import session identifier (HNK-<timestamp>) grouping all records from one upload action."
    }
  },
  "required": [
    "section_id",
    "source_section",
    "source_name_key",
    "text_content",
    "content_hash"
  ],
  "indexes": [
    {
      "name": "idx_section_id",
      "fields": [
        "section_id"
      ]
    },
    {
      "name": "idx_source_section",
      "fields": [
        "source_section"
      ]
    },
    {
      "name": "idx_source_name_key",
      "fields": [
        "source_name_key"
      ]
    },
    {
      "name": "idx_section_key",
      "fields": [
        "source_section",
        "source_name_key"
      ]
    },
    {
      "name": "idx_name_id",
      "fields": [
        "name_id"
      ]
    },
    {
      "name": "idx_content_hash",
      "fields": [
        "content_hash"
      ]
    },
    {
      "name": "idx_section_key_hash",
      "fields": [
        "source_section",
        "source_name_key",
        "content_hash"
      ]
    },
    {
      "name": "idx_section_key_page",
      "fields": [
        "source_section",
        "source_name_key",
        "source_pdf_page"
      ]
    },
    {
      "name": "idx_section_type",
      "fields": [
        "section_type"
      ]
    },
    {
      "name": "idx_import_batch",
      "fields": [
        "import_batch"
      ]
    },
    {
      "name": "idx_import_date",
      "fields": [
        "import_date"
      ]
    },
    {
      "name": "idx_section_key_type",
      "fields": [
        "source_section",
        "source_name_key",
        "section_type"
      ]
    },
    {
      "name": "idx_has_visual",
      "fields": [
        "has_visual"
      ]
    }
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}