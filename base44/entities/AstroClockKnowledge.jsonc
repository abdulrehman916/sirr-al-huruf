{
  "name": "AstroClockKnowledge",
  "type": "object",
  "description": "Timing intelligence extracted from verified manuscripts and merged into the Astro Clock. Each record is a canonical knowledge record linked to a specific weekday, day/night period, Sahath, or planetary hour. GLOBAL KNOWLEDGE CONFLICT RESOLUTION RULE: When multiple verified manuscripts provide information for the same canonical record, every newly extracted field is classified as Complementary (auto-merge), Equivalent (normalize-merge), Context-Specific (store under condition), or Conflicting (preserve both as Multiple Verified Opinions). The system never loses verified information and never blindly merges conflicting statements. Marker records (is_marker=true) prevent reprocessing and are never displayed.",
  "properties": {
    "knowledge_id": {
      "type": "string",
      "description": "Permanent unique identifier. Format: ACK-<source_entry_id>-<seq> or ACK-MARKER-<entry_id> for markers."
    },
    "source_type": {
      "type": "string",
      "enum": [
        "weekday",
        "day_period",
        "night_period",
        "sahath",
        "planetary_hour"
      ],
      "description": "Which Astro Clock section this knowledge enriches: weekday=specific weekday, day_period=daytime general, night_period=nighttime general, sahath=specific Sahath number, planetary_hour=specific planet hour"
    },
    "weekday": {
      "type": "integer",
      "description": "0=Sunday, 1=Monday, 2=Tuesday, 3=Wednesday, 4=Thursday, 5=Friday, 6=Saturday. Only for source_type=weekday, day_period, night_period. Null for sahath/planetary_hour."
    },
    "period": {
      "type": "string",
      "enum": [
        "day",
        "night"
      ],
      "description": "Day or Night period. Only for source_type=day_period, night_period, sahath. Null for weekday/planetary_hour."
    },
    "sahath_number": {
      "type": "integer",
      "description": "Sahath number 1-12. Only for source_type=sahath. Null for other source types."
    },
    "planet": {
      "type": "string",
      "description": "Planet key (sun, moon, mars, mercury, jupiter, venus, saturn). Only for source_type=planetary_hour or sahath (the ruling planet). Null for weekday/day_period/night_period."
    },
    "knowledge_category": {
      "type": "string",
      "enum": [
        "recommendation",
        "rule",
        "warning",
        "condition",
        "timing_rule",
        "suitable_time",
        "unsuitable_time",
        "special_timing"
      ],
      "description": "Type of timing knowledge"
    },
    "knowledge_text_en": {
      "type": "string",
      "description": "English text of the timing knowledge \u2014 RESOLVED text containing complementary and equivalent knowledge merged via LLM. Empty string for marker records."
    },
    "knowledge_text_ml": {
      "type": "string",
      "description": "Malayalam translation. Appended from new sources. Empty for markers."
    },
    "knowledge_text_ar": {
      "type": "string",
      "description": "Original Arabic text. Appended from new sources \u2014 never modified. Empty for markers."
    },
    "content_hash": {
      "type": "string",
      "description": "SHA-256 hash of normalized knowledge_text_en for exact duplicate detection. Marker records use no-timing-<entry_id>."
    },
    "canonical_key": {
      "type": "string",
      "description": "Canonical routing key for field-level knowledge evolution. Format: 'source_type|weekday|period|sahath_number|planet'. Records with the same canonical_key represent the same canonical topic."
    },
    "is_marker": {
      "type": "boolean",
      "default": false,
      "description": "If true, entry analyzed but no timing knowledge found. Never displayed."
    },
    "context_specific": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "condition": {
            "type": "string",
            "description": "The condition this knowledge is valid under (e.g., 'weekday:Thursday', 'sahath:8', 'planet:Mars', 'intention:love', 'material:silver')"
          },
          "text_en": {
            "type": "string"
          },
          "text_ml": {
            "type": "string"
          },
          "text_ar": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "book_title": {
                  "type": "string"
                },
                "page_number": {
                  "type": "string"
                },
                "entry_id": {
                  "type": "string"
                }
              }
            },
            "default": []
          },
          "source_count": {
            "type": "integer",
            "default": 1
          }
        }
      },
      "default": [],
      "description": "GLOBAL CONFLICT RESOLUTION RULE: Context-specific knowledge valid only under certain conditions. Stored under its matching condition without affecting other conditions."
    },
    "conflicting_opinions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string",
            "description": "Which field/topic conflicts (e.g., 'timing', 'best_suited_activity', 'method')"
          },
          "opinion_text_en": {
            "type": "string"
          },
          "opinion_text_ml": {
            "type": "string"
          },
          "opinion_text_ar": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "book_title": {
                  "type": "string"
                },
                "page_number": {
                  "type": "string"
                },
                "entry_id": {
                  "type": "string"
                }
              }
            },
            "default": []
          },
          "source_count": {
            "type": "integer",
            "default": 1
          },
          "confidence": {
            "type": "string",
            "enum": [
              "HIGH",
              "MEDIUM",
              "LOW"
            ],
            "default": "MEDIUM"
          }
        }
      },
      "default": [],
      "description": "GLOBAL CONFLICT RESOLUTION RULE: Conflicting opinions from verified sources. Both statements preserved. Each attached to its supporting sources. Marked as 'Multiple Verified Opinions'. Future manuscripts can strengthen one opinion through additional supporting sources."
    },
    "conflict_flags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "GLOBAL CONFLICT RESOLUTION RULE: List of fields that have conflicting opinions ('Multiple Verified Opinions')."
    },
    "source_book_id": {
      "type": "string",
      "description": "FK to ManuscriptBook.book_id"
    },
    "source_book_title": {
      "type": "string",
      "description": "Denormalized book title"
    },
    "source_page_number": {
      "type": "string",
      "description": "Page number"
    },
    "source_entry_id": {
      "type": "string",
      "description": "FK to ManuscriptEntry.entry_id"
    },
    "is_verified": {
      "type": "boolean",
      "default": false,
      "description": "True only if source ManuscriptEntry was verified."
    },
    "supporting_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "book_title": {
            "type": "string"
          },
          "page_number": {
            "type": "string"
          },
          "entry_id": {
            "type": "string"
          }
        }
      },
      "default": [],
      "description": "Additional manuscript sources. Updated when duplicate content_hash or canonical_key match is found."
    },
    "source_count": {
      "type": "integer",
      "default": 1,
      "description": "Total manuscript sources. 0 for markers."
    }
  },
  "required": [
    "knowledge_id",
    "source_type",
    "knowledge_category",
    "knowledge_text_en",
    "content_hash"
  ],
  "indexes": [
    {
      "name": "idx_knowledge_id",
      "fields": [
        "knowledge_id"
      ]
    },
    {
      "name": "idx_content_hash",
      "fields": [
        "content_hash"
      ]
    },
    {
      "name": "idx_canonical_key",
      "fields": [
        "canonical_key"
      ]
    },
    {
      "name": "idx_source_type",
      "fields": [
        "source_type"
      ]
    },
    {
      "name": "idx_source_type_weekday",
      "fields": [
        "source_type",
        "weekday"
      ]
    },
    {
      "name": "idx_source_type_sahath",
      "fields": [
        "source_type",
        "sahath_number"
      ]
    },
    {
      "name": "idx_source_type_planet",
      "fields": [
        "source_type",
        "planet"
      ]
    },
    {
      "name": "idx_is_marker",
      "fields": [
        "is_marker"
      ]
    },
    {
      "name": "idx_is_verified",
      "fields": [
        "is_verified"
      ]
    },
    {
      "name": "idx_source_book_id",
      "fields": [
        "source_book_id"
      ]
    },
    {
      "name": "idx_source_entry_id",
      "fields": [
        "source_entry_id"
      ]
    },
    {
      "name": "idx_conflict_flags",
      "fields": [
        "conflict_flags"
      ]
    }
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}