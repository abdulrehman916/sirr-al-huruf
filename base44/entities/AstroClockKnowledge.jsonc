{
  "name": "AstroClockKnowledge",
  "type": "object",
  "description": "Timing intelligence extracted from verified manuscripts, screenshots, and merged into the Astro Clock. FULL-CONTEXT INDEXING RULE: Every knowledge record is indexed by the complete context \u2014 Weekday + Day/Night + Sa'at Number (1-24) + Governing Kawkab + Nakshatra/Manzil (if applicable). Knowledge is NEVER stored by planet name alone. Two records for the same Kawkab but different weekdays are DIFFERENT records. When the manuscript cycle returns to the same Day + Sa'at + Kawkab combination, the same canonical knowledge is displayed. GLOBAL MERGE RULE: When multiple sources (manuscripts, screenshots) provide information for the same full-context combination, unique recommendations are merged, duplicates are removed, every source reference is preserved, and existing knowledge is NEVER overwritten or deleted. Conflicting opinions are preserved as 'Multiple Verified Opinions'. Marker records (is_marker=true) prevent reprocessing and are never displayed.",
  "properties": {
    "knowledge_id": {
      "type": "string",
      "description": "Permanent unique identifier. Format: ACK-<source_entry_id>-<seq>, ACK-SCR-<timestamp>-<rand> for screenshots, or ACK-MARKER-<entry_id> for markers."
    },
    "source_type": {
      "type": "string",
      "enum": [
        "weekday",
        "day_period",
        "night_period",
        "sahath",
        "planetary_hour",
        "full_context"
      ],
      "description": "Which Astro Clock section this knowledge enriches. 'full_context' = indexed by the complete Weekday+Period+Saat+Kawkab+Nakshatra combination (screenshot-sourced records use this). Legacy types retained for backward compatibility."
    },
    "weekday": {
      "type": "integer",
      "description": "0=Sunday, 1=Monday, 2=Tuesday, 3=Wednesday, 4=Thursday, 5=Friday, 6=Saturday. REQUIRED for full_context records \u2014 every knowledge record must specify its weekday."
    },
    "period": {
      "type": "string",
      "enum": [
        "day",
        "night"
      ],
      "description": "Day or Night period. REQUIRED for full_context records."
    },
    "sahath_number": {
      "type": "integer",
      "description": "Legacy Sahath number 1-12 (per-period). Retained for backward compatibility with manuscript enrichment."
    },
    "saat_number": {
      "type": "integer",
      "description": "FULL-CONTEXT Sa'at number 1-24. 1-12 = daytime hours, 13-24 = nighttime hours. REQUIRED for full_context records \u2014 uniquely identifies the planetary hour within the 24-hour cycle."
    },
    "planet": {
      "type": "string",
      "description": "Governing Kawkab / planet key (sun, moon, mars, mercury, jupiter, venus, saturn). For full_context records, this is the Kawkab ruling this specific Sa'at."
    },
    "nakshatra": {
      "type": "string",
      "description": "Lunar mansion / Manzil name if the knowledge is specific to a nakshatra. Empty if not applicable. Part of the full context key."
    },
    "full_context_key": {
      "type": "string",
      "description": "FULL-CONTEXT INDEX KEY. Format: 'weekday|period|saat_number|kawkab|nakshatra'. Every full_context record uses this key. Two records with the same key represent the same canonical Day+Saat+Kawkab combination and are merged \u2014 never duplicated."
    },
    "knowledge_category": {
      "type": "string",
      "enum": [
        "recommendation",
        "rule",
        "warning",
        "condition",
        "timing_rule",
        "suitable_time",
        "unsuitable_time",
        "special_timing",
        "full_context_rule"
      ],
      "description": "Type of timing knowledge. 'full_context_rule' = complete Day+Saat+Kawkab rule with action arrays."
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "en": {
            "type": "string"
          },
          "ml": {
            "type": "string"
          },
          "ar": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "book_title": {
                  "type": "string"
                },
                "page_number": {
                  "type": "string"
                },
                "entry_id": {
                  "type": "string"
                },
                "screenshot_url": {
                  "type": "string"
                }
              }
            },
            "default": []
          }
        },
        "required": [
          "en"
        ]
      },
      "default": [],
      "description": "FULL-CONTEXT: Actions recommended for this exact Day+Saat+Kawkab. Unique items only \u2014 duplicates removed during merge. Every source preserved."
    },
    "forbidden_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "en": {
            "type": "string"
          },
          "ml": {
            "type": "string"
          },
          "ar": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "book_title": {
                  "type": "string"
                },
                "page_number": {
                  "type": "string"
                },
                "entry_id": {
                  "type": "string"
                },
                "screenshot_url": {
                  "type": "string"
                }
              }
            },
            "default": []
          }
        },
        "required": [
          "en"
        ]
      },
      "default": [],
      "description": "FULL-CONTEXT: Actions forbidden / to be avoided for this exact Day+Saat+Kawkab. Unique items only. Every source preserved."
    },
    "enemy_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "en": {
            "type": "string"
          },
          "ml": {
            "type": "string"
          },
          "ar": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "book_title": {
                  "type": "string"
                },
                "page_number": {
                  "type": "string"
                },
                "entry_id": {
                  "type": "string"
                },
                "screenshot_url": {
                  "type": "string"
                }
              }
            },
            "default": []
          }
        },
        "required": [
          "en"
        ]
      },
      "default": [],
      "description": "FULL-CONTEXT: Enemy-related actions for this exact Day+Saat+Kawkab. Unique items only. Every source preserved."
    },
    "friendship_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "en": {
            "type": "string"
          },
          "ml": {
            "type": "string"
          },
          "ar": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "book_title": {
                  "type": "string"
                },
                "page_number": {
                  "type": "string"
                },
                "entry_id": {
                  "type": "string"
                },
                "screenshot_url": {
                  "type": "string"
                }
              }
            },
            "default": []
          }
        },
        "required": [
          "en"
        ]
      },
      "default": [],
      "description": "FULL-CONTEXT: Friendship-related actions for this exact Day+Saat+Kawkab. Unique items only. Every source preserved."
    },
    "ritual_suitability": {
      "type": "string",
      "description": "FULL-CONTEXT: Ritual suitability assessment for this exact Day+Saat+Kawkab. Describes which ritual types are suitable and why."
    },
    "warnings_list": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "en": {
            "type": "string"
          },
          "ml": {
            "type": "string"
          },
          "ar": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "book_title": {
                  "type": "string"
                },
                "page_number": {
                  "type": "string"
                },
                "entry_id": {
                  "type": "string"
                },
                "screenshot_url": {
                  "type": "string"
                }
              }
            },
            "default": []
          }
        },
        "required": [
          "en"
        ]
      },
      "default": [],
      "description": "FULL-CONTEXT: Warnings for this exact Day+Saat+Kawkab. Unique items only. Every source preserved."
    },
    "notes_list": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "en": {
            "type": "string"
          },
          "ml": {
            "type": "string"
          },
          "ar": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "book_title": {
                  "type": "string"
                },
                "page_number": {
                  "type": "string"
                },
                "entry_id": {
                  "type": "string"
                },
                "screenshot_url": {
                  "type": "string"
                }
              }
            },
            "default": []
          }
        },
        "required": [
          "en"
        ]
      },
      "default": [],
      "description": "FULL-CONTEXT: Additional notes for this exact Day+Saat+Kawkab. Unique items only. Every source preserved."
    },
    "knowledge_text_en": {
      "type": "string",
      "description": "English text of the timing knowledge \u2014 RESOLVED text containing complementary and equivalent knowledge merged via LLM. Empty string for marker records. For full_context records, this is a summary of the complete rule."
    },
    "knowledge_text_ml": {
      "type": "string",
      "description": "Malayalam translation. Appended from new sources. Empty for markers."
    },
    "knowledge_text_ar": {
      "type": "string",
      "description": "Original Arabic text. Appended from new sources \u2014 never modified. Empty for markers."
    },
    "content_hash": {
      "type": "string",
      "description": "SHA-256 hash of normalized knowledge_text_en for exact duplicate detection. Marker records use no-timing-<entry_id>. Screenshot records use scr-<full_context_key>-<hash of first action>."
    },
    "canonical_key": {
      "type": "string",
      "description": "Legacy canonical routing key. Format: 'source_type|weekday|period|sahath_number|planet'. Retained for backward compatibility with manuscript enrichment."
    },
    "is_marker": {
      "type": "boolean",
      "default": false,
      "description": "If true, entry analyzed but no timing knowledge found. Never displayed."
    },
    "context_specific": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "condition": {
            "type": "string",
            "description": "The condition this knowledge is valid under (e.g., 'weekday:Thursday', 'sahath:8', 'planet:Mars', 'intention:love', 'material:silver')"
          },
          "text_en": {
            "type": "string"
          },
          "text_ml": {
            "type": "string"
          },
          "text_ar": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "book_title": {
                  "type": "string"
                },
                "page_number": {
                  "type": "string"
                },
                "entry_id": {
                  "type": "string"
                },
                "screenshot_url": {
                  "type": "string"
                }
              }
            },
            "default": []
          },
          "source_count": {
            "type": "integer",
            "default": 1
          }
        }
      },
      "default": [],
      "description": "GLOBAL CONFLICT RESOLUTION RULE: Context-specific knowledge valid only under certain conditions. Stored under its matching condition without affecting other conditions."
    },
    "conflicting_opinions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string",
            "description": "Which field/topic conflicts (e.g., 'timing', 'best_suited_activity', 'method', 'recommended_actions', 'forbidden_actions')"
          },
          "opinion_text_en": {
            "type": "string"
          },
          "opinion_text_ml": {
            "type": "string"
          },
          "opinion_text_ar": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "book_title": {
                  "type": "string"
                },
                "page_number": {
                  "type": "string"
                },
                "entry_id": {
                  "type": "string"
                },
                "screenshot_url": {
                  "type": "string"
                }
              }
            },
            "default": []
          },
          "source_count": {
            "type": "integer",
            "default": 1
          },
          "confidence": {
            "type": "string",
            "enum": [
              "HIGH",
              "MEDIUM",
              "LOW"
            ],
            "default": "MEDIUM"
          }
        }
      },
      "default": [],
      "description": "GLOBAL CONFLICT RESOLUTION RULE: Conflicting opinions from verified sources. Both statements preserved. Each attached to its supporting sources. Marked as 'Multiple Verified Opinions'."
    },
    "conflict_flags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "GLOBAL CONFLICT RESOLUTION RULE: List of fields that have conflicting opinions ('Multiple Verified Opinions')."
    },
    "source_book_id": {
      "type": "string",
      "description": "FK to ManuscriptBook.book_id. Empty for screenshot-sourced records."
    },
    "source_book_title": {
      "type": "string",
      "description": "Denormalized book title. For screenshots, this is 'Screenshot Upload'."
    },
    "source_page_number": {
      "type": "string",
      "description": "Page number. For screenshots, empty."
    },
    "source_entry_id": {
      "type": "string",
      "description": "FK to ManuscriptEntry.entry_id. Empty for screenshot-sourced records."
    },
    "source_screenshot_url": {
      "type": "string",
      "description": "URL of the source screenshot image (for screenshot-sourced records). Preserved permanently for provenance."
    },
    "is_verified": {
      "type": "boolean",
      "default": false,
      "description": "True only if source ManuscriptEntry was verified. Screenshot records default to false (admin-reviewed)."
    },
    "supporting_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "book_title": {
            "type": "string"
          },
          "page_number": {
            "type": "string"
          },
          "entry_id": {
            "type": "string"
          },
          "screenshot_url": {
            "type": "string"
          }
        }
      },
      "default": [],
      "description": "Additional manuscript/screenshot sources. Updated when duplicate content_hash or full_context_key match is found. Every source is preserved permanently."
    },
    "source_count": {
      "type": "integer",
      "default": 1,
      "description": "Total manuscript/screenshot sources. 0 for markers."
    }
  },
  "required": [
    "knowledge_id",
    "source_type",
    "knowledge_category",
    "knowledge_text_en",
    "content_hash"
  ],
  "indexes": [
    {
      "name": "idx_knowledge_id",
      "fields": [
        "knowledge_id"
      ]
    },
    {
      "name": "idx_content_hash",
      "fields": [
        "content_hash"
      ]
    },
    {
      "name": "idx_canonical_key",
      "fields": [
        "canonical_key"
      ]
    },
    {
      "name": "idx_full_context_key",
      "fields": [
        "full_context_key"
      ]
    },
    {
      "name": "idx_context_lookup",
      "fields": [
        "weekday",
        "period",
        "saat_number",
        "planet"
      ]
    },
    {
      "name": "idx_saat_number",
      "fields": [
        "saat_number"
      ]
    },
    {
      "name": "idx_source_type",
      "fields": [
        "source_type"
      ]
    },
    {
      "name": "idx_source_type_weekday",
      "fields": [
        "source_type",
        "weekday"
      ]
    },
    {
      "name": "idx_source_type_sahath",
      "fields": [
        "source_type",
        "sahath_number"
      ]
    },
    {
      "name": "idx_source_type_planet",
      "fields": [
        "source_type",
        "planet"
      ]
    },
    {
      "name": "idx_is_marker",
      "fields": [
        "is_marker"
      ]
    },
    {
      "name": "idx_is_verified",
      "fields": [
        "is_verified"
      ]
    },
    {
      "name": "idx_source_book_id",
      "fields": [
        "source_book_id"
      ]
    },
    {
      "name": "idx_source_entry_id",
      "fields": [
        "source_entry_id"
      ]
    },
    {
      "name": "idx_conflict_flags",
      "fields": [
        "conflict_flags"
      ]
    }
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}