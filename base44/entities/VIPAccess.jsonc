{
  "name": "VIPAccess",
  "type": "object",
  "properties": {
    "identifier": {
      "type": "string",
      "description": "Phone number or email address of the VIP user"
    },
    "identifier_type": {
      "type": "string",
      "enum": [
        "PHONE",
        "EMAIL"
      ],
      "description": "Type of identifier"
    },
    "label": {
      "type": "string",
      "description": "Optional label/name for this VIP entry"
    },
    "page_paths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of page paths this VIP can access for free. Empty array means ALL pages."
    },
    "grant_all": {
      "type": "boolean",
      "default": false,
      "description": "If true, grants access to all pages"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Is this VIP entry active"
    },
    "added_by": {
      "type": "string",
      "description": "Admin user ID who added this VIP"
    },
    "notes": {
      "type": "string",
      "description": "Admin notes"
    }
  },
  "required": [
    "identifier",
    "identifier_type",
    "is_active"
  ]
}