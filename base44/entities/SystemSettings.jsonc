{
  "name": "SystemSettings",
  "type": "object",
  "properties": {
    "settings_id": {
      "type": "string",
      "description": "Unique settings record ID e.g. SETTINGS-MAIN"
    },
    "general": {
      "type": "object",
      "properties": {
        "app_name": {
          "type": "string",
          "description": "Application display name"
        },
        "logo_url": {
          "type": "string",
          "description": "Logo image URL"
        },
        "favicon_url": {
          "type": "string",
          "description": "Favicon URL"
        },
        "support_email": {
          "type": "string",
          "description": "Support contact email"
        },
        "whatsapp_number": {
          "type": "string",
          "description": "Primary WhatsApp number"
        },
        "telegram_link": {
          "type": "string",
          "description": "Telegram channel/group link"
        },
        "default_language": {
          "type": "string",
          "description": "Default app language code e.g. en, ml, ar"
        },
        "timezone": {
          "type": "string",
          "description": "App default timezone e.g. Asia/Dubai"
        }
      },
      "description": "General application settings"
    },
    "registration": {
      "type": "object",
      "properties": {
        "enable_registration": {
          "type": "boolean",
          "default": true,
          "description": "Allow new user registration"
        },
        "enable_guest_access": {
          "type": "boolean",
          "default": true,
          "description": "Allow guest (non-authenticated) access"
        },
        "email_verification": {
          "type": "boolean",
          "default": true,
          "description": "Require email verification on registration"
        },
        "whatsapp_verification": {
          "type": "boolean",
          "default": false,
          "description": "Require WhatsApp verification"
        }
      },
      "description": "Registration and access control settings"
    },
    "reading_codes": {
      "type": "object",
      "properties": {
        "auto_approve": {
          "type": "boolean",
          "default": false,
          "description": "Automatically approve redeem codes without admin review"
        },
        "manual_approval": {
          "type": "boolean",
          "default": true,
          "description": "Require manual admin approval for redeem codes"
        },
        "max_redemption_attempts": {
          "type": "integer",
          "default": 3,
          "description": "Maximum code redemption attempts before lockout"
        },
        "expiry_days": {
          "type": "integer",
          "default": 365,
          "description": "Default code expiry in days (0 = lifetime)"
        }
      },
      "description": "Reading code approval and redemption settings"
    },
    "subscription": {
      "type": "object",
      "properties": {
        "currency": {
          "type": "string",
          "default": "AED",
          "description": "Default currency code"
        },
        "tax_percentage": {
          "type": "number",
          "default": 0,
          "description": "Tax percentage applied to subscriptions"
        },
        "trial_period_days": {
          "type": "integer",
          "default": 0,
          "description": "Trial period in days (0 = no trial)"
        },
        "renewal_reminder_days": {
          "type": "integer",
          "default": 7,
          "description": "Days before expiry to send renewal reminder"
        },
        "grace_period_days": {
          "type": "integer",
          "default": 3,
          "description": "Grace period after expiry before access revoked"
        }
      },
      "description": "Subscription and billing settings"
    },
    "security": {
      "type": "object",
      "properties": {
        "maintenance_mode": {
          "type": "boolean",
          "default": false,
          "description": "When true, only admins can access the app"
        },
        "force_logout_all": {
          "type": "boolean",
          "default": false,
          "description": "Force logout all non-admin users on next request"
        },
        "session_timeout_minutes": {
          "type": "integer",
          "default": 60,
          "description": "Session timeout in minutes"
        },
        "device_reset_limit": {
          "type": "integer",
          "default": 3,
          "description": "Maximum device resets per code before admin lockout"
        },
        "login_attempt_limit": {
          "type": "integer",
          "default": 5,
          "description": "Maximum failed login attempts before lockout"
        }
      },
      "description": "Security and access control settings"
    },
    "notifications": {
      "type": "object",
      "properties": {
        "email_notifications": {
          "type": "boolean",
          "default": true,
          "description": "Send email notifications to users"
        },
        "whatsapp_notifications": {
          "type": "boolean",
          "default": false,
          "description": "Send WhatsApp notifications"
        },
        "push_notifications": {
          "type": "boolean",
          "default": false,
          "description": "Send push notifications"
        }
      },
      "description": "Notification channel settings"
    },
    "backup": {
      "type": "object",
      "properties": {
        "last_export_at": {
          "type": "string",
          "description": "ISO 8601 timestamp of last settings export"
        },
        "last_import_at": {
          "type": "string",
          "description": "ISO 8601 timestamp of last settings import"
        },
        "last_backup_at": {
          "type": "string",
          "description": "ISO 8601 timestamp of last database config backup"
        },
        "last_restore_at": {
          "type": "string",
          "description": "ISO 8601 timestamp of last config restore"
        }
      },
      "description": "Backup and restore metadata"
    },
    "updated_by": {
      "type": "string",
      "description": "Admin user ID who last updated settings"
    },
    "updated_by_name": {
      "type": "string",
      "description": "Admin display name"
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of last update"
    },
    "audit_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string"
          },
          "user_id": {
            "type": "string"
          },
          "user_name": {
            "type": "string"
          },
          "user_role": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "section": {
            "type": "string"
          },
          "previous_value": {
            "type": "string"
          },
          "new_value": {
            "type": "string"
          }
        }
      },
      "description": "Audit trail of all settings changes"
    }
  },
  "required": [
    "settings_id"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}