{
  "name": "SirrManuscriptEntry",
  "type": "object",
  "description": "SIRR-MODULE-ISOLATED permanent manuscript entry collection. Completely separate from the global ManuscriptEntry entity. The SIRR import is a FAITHFUL DIGITAL MANUSCRIPT ARCHIVE \u2014 the uploaded PDF is the ONLY source of truth. Each record is one PAGE/SECTION of a SIRR-uploaded PDF, transcribed VERBATIM (every Arabic letter, harakah, punctuation, paragraph, line break preserved) in exact page order. No content is ever rewritten, summarized, paraphrased, or regenerated by AI. No introductions, benefits, warnings, or explanations are generated. Arabic is NEVER auto-translated; malayalam_meaning holds only the Malayalam translation of explanatory text printed in the manuscript (if any). A Malayalam navigation title (heading_title_ml) is created ONLY for navigation when the manuscript has no Malayalam title. Pages with OCR confidence below 100 are flagged needs_review=true for manual review instead of guessing. PERMANENT RELATIONSHIPS (RULE 8): every card permanently carries its sirr_book_id (Book), source_part_id + source_part_number (PDF Part), ocr_confidence (OCR Output), arabic_text (Arabic Text), arabic_normalized (harakat-stripped Arabic for indexed partial search), malayalam_meaning (Malayalam Meaning), category (Categories), and is linked to the book's verification_status + the SirrAuditLog (Verification + Audit History). SOURCE RETENTION: every card permanently carries its sirr_book_id, source_part_id, source_part_number and page_number so its exact origin is always known. SCALABLE SEARCH (RULES 1, 3, 4): arabic_normalized is indexed for database-side partial Arabic matching without harakat; every searchable field (sirr_book_id, category, book_title, heading_title_ar, heading_title_ml, entry_order) is indexed. ISOLATED \u2014 only the SIRR ingestSirrManuscript backend function may write to this entity. Designed to scale to millions of entries across thousands of books.",
  "properties": {
    "sirr_entry_id": {
      "type": "string",
      "description": "Permanent unique identifier for this SIRR entry (page/section). Never changes."
    },
    "sirr_book_id": {
      "type": "string",
      "description": "FK to SirrManuscriptBook.sirr_book_id. The SIRR book this entry belongs to. Permanent."
    },
    "source_part_id": {
      "type": "string",
      "default": "",
      "description": "PERMANENT FK to the originating PDF part (SirrManuscriptBook.pdf_parts[].part_id). Every card always knows which PDF part it was extracted from. Never changes."
    },
    "source_part_number": {
      "type": "integer",
      "default": 0,
      "description": "The part number (1-based) of the PDF part this entry was extracted from. Preserved permanently for source provenance."
    },
    "entry_order": {
      "type": "integer",
      "default": 0,
      "description": "Global sequential position across the whole book (across all parts), preserving exact manuscript order. 1-based. Indexed for cursor pagination in sirrSearchEntries."
    },
    "category": {
      "type": "string",
      "default": "",
      "description": "PERMANENT CATEGORY relationship (RULE 8). The manuscript-defined category/classification of this section, assigned by the LLM from the section content. Known values: dua, dhikr, wird, hizb, amal, ruqyah, talisman, wafq, prayer, instruction, general. Indexed for category-based queries across millions of cards. Empty only when the manuscript gives no clue to classify the section."
    },
    "heading_title_ml": {
      "type": "string",
      "default": "",
      "description": "SHORT Malayalam NAVIGATION label ONLY, created when the manuscript has no Malayalam title for this section. Never a translation of content. Never a generic name like 'Dua 1'."
    },
    "heading_title_ar": {
      "type": "string",
      "default": "",
      "description": "Original heading exactly as printed on the page, transcribed verbatim (with harakat). Only set when the manuscript prints a heading on this page. Never invented."
    },
    "heading_title": {
      "type": "string",
      "default": "",
      "description": "Original heading in its source language / transliteration for reference. Not the primary display title."
    },
    "arabic_text": {
      "type": "string",
      "default": "",
      "description": "VERBATIM transcription of EVERYTHING printed on the page (Arabic / Ottoman Turkish / English / Malayalam as printed). Every letter, harakah, punctuation mark, paragraph, and line break preserved exactly. Never rewritten, summarized, or regenerated. If the manuscript itself contains a Malayalam translation on the page, it is preserved here as part of the verbatim text \u2014 never auto-generated."
    },
    "arabic_normalized": {
      "type": "string",
      "default": "",
      "description": "Arabic text WITHOUT harakat (diacritics stripped) and without tatweel, normalized for indexed O(1) database-side PARTIAL search matching. Populated during extraction. Used by sirrSearchEntries for Arabic partial/exact search so users can find text whether or not they type the diacritics. The verbatim arabic_text is always preserved separately."
    },
    "malayalam_meaning": {
      "type": "string",
      "default": "",
      "description": "Malayalam translation of the EXPLANATORY text only (when the manuscript prints explanatory text in Indonesian/Malay/another language). Arabic duas are NEVER auto-translated. Empty when no explanatory text exists."
    },
    "english_meaning": {
      "type": "string",
      "default": "",
      "description": "Empty unless the manuscript itself prints an English translation on the page (then it is part of arabic_text). Never auto-generated."
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Original page image URLs from the manuscript. Original images only \u2014 never redrawn."
    },
    "page_number": {
      "type": "string",
      "default": "",
      "description": "Page number in the source PDF (string for display). Shown in the reference footer."
    },
    "book_title": {
      "type": "string",
      "default": "",
      "description": "Denormalized original book title for the reference footer and cross-book search."
    },
    "ocr_confidence": {
      "type": "number",
      "default": 100,
      "description": "OCR / transcription confidence for this page (0-100). 100 only when every character is certain. Below 100 means some text was uncertain \u2014 the page is flagged for manual review."
    },
    "needs_review": {
      "type": "boolean",
      "default": false,
      "description": "True when ocr_confidence < 100. The page is flagged for manual review instead of trusting uncertain text. Never guesses or invents missing words."
    },
    "has_malayalam": {
      "type": "boolean",
      "default": false,
      "description": "True if the page itself contains Malayalam text (which is already preserved in arabic_text as part of the verbatim transcription)."
    }
  },
  "required": [
    "sirr_entry_id",
    "sirr_book_id",
    "entry_order"
  ],
  "indexes": [
    {
      "name": "idx_sirr_entry_id",
      "fields": [
        "sirr_entry_id"
      ]
    },
    {
      "name": "idx_sirr_book_id",
      "fields": [
        "sirr_book_id"
      ]
    },
    {
      "name": "idx_source_part_id",
      "fields": [
        "source_part_id"
      ]
    },
    {
      "name": "idx_entry_order",
      "fields": [
        "entry_order"
      ]
    },
    {
      "name": "idx_sirr_book_order",
      "fields": [
        "sirr_book_id",
        "entry_order"
      ]
    },
    {
      "name": "idx_needs_review",
      "fields": [
        "needs_review"
      ]
    },
    {
      "name": "idx_heading_title_ar",
      "fields": [
        "heading_title_ar"
      ]
    },
    {
      "name": "idx_heading_title_ml",
      "fields": [
        "heading_title_ml"
      ]
    },
    {
      "name": "idx_book_title",
      "fields": [
        "book_title"
      ]
    },
    {
      "name": "idx_book_part_order",
      "fields": [
        "sirr_book_id",
        "source_part_id",
        "entry_order"
      ]
    },
    {
      "name": "idx_category",
      "fields": [
        "category"
      ]
    },
    {
      "name": "idx_sirr_book_category",
      "fields": [
        "sirr_book_id",
        "category"
      ]
    },
    {
      "name": "idx_arabic_normalized",
      "fields": [
        "arabic_normalized"
      ]
    }
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}