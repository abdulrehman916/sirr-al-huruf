{
  "name": "SirrManuscriptBook",
  "type": "object",
  "description": "SIRR-MODULE-ISOLATED manuscript book collection. Completely separate from the global ManuscriptBook entity. The SIRR page reads ONLY from this entity. MULTI-PART PERMANENT STORAGE: A single book may be built from multiple uploaded PDF parts (Part 1, Part 2, ... Part N). Every uploaded PDF URL is permanently stored in the pdf_parts array immediately at upload time \u2014 never kept only in conversation state. The background engine (sirrProcessNextChunk) rebuilds exclusively from the stored pdf_parts list, never from chat history. current_part_index tracks which part is being processed; last_processed_page tracks progress within the current part. combined_total_pages is the true total across all parts. UPLOAD-THEN-PROCESS FLOW: While the user is still uploading parts, extraction_status stays 'uploading' \u2014 the background engine IGNORES books in this state, so processing NEVER begins until the user explicitly clicks 'Begin Processing', which flips the status to 'pending'. ISOLATED \u2014 only the SIRR ingestSirrManuscript backend function, sirrProcessNextChunk, and SIRR-only UI logic may write to this entity.",
  "properties": {
    "sirr_book_id": {
      "type": "string",
      "description": "Permanent unique identifier for this SIRR book. Never changes. Used as FK in SirrManuscriptEntry."
    },
    "malayalam_book_name": {
      "type": "string",
      "default": "",
      "description": "Malayalam display name for the book. Editable by the user from the SIRR library. Shown as the primary book title in the SIRR UI."
    },
    "book_title": {
      "type": "string",
      "description": "Original book title exactly as imported (original language preserved \u2014 never translated)."
    },
    "book_title_ar": {
      "type": "string",
      "default": "",
      "description": "Arabic title if applicable. Preserved verbatim."
    },
    "author": {
      "type": "string",
      "default": "",
      "description": "Author or scribe of the manuscript."
    },
    "language": {
      "type": "string",
      "default": "",
      "description": "Primary language of the manuscript (ar, tr, en, ...)."
    },
    "edition": {
      "type": "string",
      "default": "",
      "description": "Edition of the manuscript if available."
    },
    "volume": {
      "type": "string",
      "default": "",
      "description": "Volume of the manuscript if available."
    },
    "publication_year": {
      "type": "string",
      "default": "",
      "description": "Year of publication or printing if available."
    },
    "total_pages": {
      "type": "integer",
      "default": 0,
      "description": "Page count of the CURRENT part being processed (informational). The true combined total is combined_total_pages."
    },
    "combined_total_pages": {
      "type": "integer",
      "default": 0,
      "description": "TRUE combined page count across ALL uploaded PDF parts. Sum of every pdf_parts[].page_count. Set by sirrProcessNextChunk as parts are processed. This is the authoritative total \u2014 never overwritten by a single part's count."
    },
    "last_processed_page": {
      "type": "integer",
      "default": 0,
      "description": "Last page successfully processed WITHIN the current part (1-based). The background processor resumes from last_processed_page+1 within the current part. When the current part is fully processed, current_part_index advances and this resets to 0."
    },
    "current_part_index": {
      "type": "integer",
      "default": 0,
      "description": "Index (0-based) into pdf_parts of the part currently being processed. When current_part_index >= pdf_parts.length, all parts are done and extraction_status becomes 'completed'. The processor never depends on chat history \u2014 it reads this field and the pdf_parts array from the database."
    },
    "pdf_parts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "part_number": {
            "type": "integer",
            "description": "1-based part sequence number (Part 1, Part 2, ...)."
          },
          "file_url": {
            "type": "string",
            "description": "PERMANENT URL to this PDF part. Saved immediately at upload time. Never lost."
          },
          "file_name": {
            "type": "string",
            "description": "Original file name of this PDF part."
          },
          "page_start": {
            "type": "integer",
            "default": 1,
            "description": "First page of this part within the part's own numbering (always 1)."
          },
          "page_end": {
            "type": "integer",
            "default": 0,
            "description": "Last page processed so far in this part. Equals page_count when the part is fully processed."
          },
          "page_count": {
            "type": "integer",
            "default": 0,
            "description": "Total page count of this PDF part, determined by the LLM during first chunk extraction. 0 until the first chunk runs."
          },
          "uploaded_at": {
            "type": "string",
            "description": "ISO 8601 timestamp when this part was uploaded."
          },
          "processed": {
            "type": "boolean",
            "default": false,
            "description": "True when this part is fully processed (page_end >= page_count)."
          }
        },
        "required": [
          "part_number",
          "file_url",
          "file_name"
        ]
      },
      "default": [],
      "description": "ORDERED LIST of every uploaded PDF part for this book. Part 1, Part 2, ... Part N. Every part's file_url is permanently stored here at upload time. The background engine processes parts in order. Adding a new part appends to this array and keeps extraction_status at 'uploading'. This is the SOLE source of truth for what to process \u2014 never chat history."
    },
    "original_file_url": {
      "type": "string",
      "default": "",
      "description": "LEGACY: URL of the first PDF part. Kept for backward compatibility. New uploads populate pdf_parts[0].file_url instead."
    },
    "original_file_name": {
      "type": "string",
      "default": "",
      "description": "LEGACY: Original file name of the first PDF part. Kept for backward compatibility."
    },
    "source": {
      "type": "string",
      "default": "sirr_upload",
      "description": "How this book entered the SIRR store. Always SIRR-specific."
    },
    "upload_date": {
      "type": "string",
      "description": "ISO 8601 date when this book was first uploaded into the SIRR module."
    },
    "extraction_status": {
      "type": "string",
      "enum": [
        "uploading",
        "pending",
        "processing",
        "completed",
        "failed",
        "partial"
      ],
      "default": "pending",
      "description": "Content extraction status. 'uploading' = user is still uploading PDF parts; the background engine IGNORES this state so processing never begins until the user clicks 'Begin Processing'. 'pending' = all parts uploaded, waiting for background processor. 'processing' = a part is being extracted. 'completed' = ALL parts fully processed. 'partial' = interrupted, scheduled automation will resume. Never shown to users."
    },
    "extraction_error": {
      "type": "string",
      "default": "",
      "description": "Error message if extraction_status is failed or partial."
    },
    "total_entries": {
      "type": "integer",
      "default": 0,
      "description": "Total number of SirrManuscriptEntry records extracted from this book (across all parts)."
    },
    "notes": {
      "type": "string",
      "default": "",
      "description": "Admin notes about this SIRR manuscript."
    }
  },
  "required": [
    "sirr_book_id",
    "book_title",
    "extraction_status"
  ],
  "indexes": [
    {
      "name": "idx_sirr_book_id",
      "fields": [
        "sirr_book_id"
      ]
    },
    {
      "name": "idx_source",
      "fields": [
        "source"
      ]
    },
    {
      "name": "idx_extraction_status",
      "fields": [
        "extraction_status"
      ]
    },
    {
      "name": "idx_upload_date",
      "fields": [
        "upload_date"
      ]
    },
    {
      "name": "idx_status_upload_date",
      "fields": [
        "extraction_status",
        "upload_date"
      ]
    },
    {
      "name": "idx_last_processed_page",
      "fields": [
        "last_processed_page"
      ]
    },
    {
      "name": "idx_current_part_index",
      "fields": [
        "current_part_index"
      ]
    }
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}