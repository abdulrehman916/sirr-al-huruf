{
  "name": "SirrManuscriptBook",
  "type": "object",
  "description": "SIRR-MODULE-ISOLATED manuscript book collection. Completely separate from the global ManuscriptBook entity used by Astro Clock, Reference Library, and Import History. The SIRR page reads ONLY from this entity \u2014 it never connects to ManuscriptBook. Starts empty. A book appears here ONLY when a PDF is uploaded specifically for the SIRR module via the SIRR upload button. No records are shared, copied, or synced from any other module's manuscript store. ISOLATED \u2014 only the SIRR ingestSirrManuscript backend function and SIRR-only UI logic may write to this entity. BACKGROUND ENGINE: After upload, extraction_status='pending' and last_processed_page=0. The sirrProcessNextChunk background processor and scheduled automation read last_processed_page to resume automatically \u2014 never requires manual restart.",
  "properties": {
    "sirr_book_id": {
      "type": "string",
      "description": "Permanent unique identifier for this SIRR book. Never changes. Used as FK in SirrManuscriptEntry."
    },
    "malayalam_book_name": {
      "type": "string",
      "default": "",
      "description": "Malayalam display name for the book. Editable by the user from the SIRR library. Shown as the primary book title in the SIRR UI. If the manuscript has no Malayalam title, only the title is translated into Malayalam (nothing else)."
    },
    "book_title": {
      "type": "string",
      "description": "Original book title exactly as imported (original language preserved \u2014 never translated)."
    },
    "book_title_ar": {
      "type": "string",
      "default": "",
      "description": "Arabic title if applicable. Preserved verbatim."
    },
    "author": {
      "type": "string",
      "default": "",
      "description": "Author or scribe of the manuscript."
    },
    "language": {
      "type": "string",
      "default": "",
      "description": "Primary language of the manuscript (ar, tr, en, ...)."
    },
    "edition": {
      "type": "string",
      "default": "",
      "description": "Edition of the manuscript if available. Shown in the reference footer."
    },
    "volume": {
      "type": "string",
      "default": "",
      "description": "Volume of the manuscript if available. Shown in the reference footer."
    },
    "publication_year": {
      "type": "string",
      "default": "",
      "description": "Year of publication or printing if available."
    },
    "total_pages": {
      "type": "integer",
      "default": 0,
      "description": "Total number of pages in the source PDF. 0 until the first chunk determines it from the LLM. Used by the background processor to know when extraction is complete."
    },
    "last_processed_page": {
      "type": "integer",
      "default": 0,
      "description": "Last page successfully processed during chunked background ingestion. 0 = not started. The sirrProcessNextChunk background processor resumes from last_processed_page+1 automatically. When last_processed_page >= total_pages, extraction is complete."
    },
    "original_file_url": {
      "type": "string",
      "default": "",
      "description": "Permanent URL to the original PDF file. The original PDF remains the master source and is stored permanently in SIRR storage."
    },
    "original_file_name": {
      "type": "string",
      "default": "",
      "description": "Original file name of the uploaded PDF. Shown as the Source in the reference footer."
    },
    "source": {
      "type": "string",
      "default": "sirr_upload",
      "description": "How this book entered the SIRR store. Always SIRR-specific (never onedrive-global or shared)."
    },
    "upload_date": {
      "type": "string",
      "description": "ISO 8601 date when this book was uploaded into the SIRR module."
    },
    "extraction_status": {
      "type": "string",
      "enum": [
        "pending",
        "processing",
        "completed",
        "failed",
        "partial"
      ],
      "default": "pending",
      "description": "Content extraction status for this SIRR book. 'pending' = uploaded, waiting for background processor. 'processing' = background engine is extracting pages. 'completed' = all pages processed. 'partial' = interrupted, scheduled automation will resume. Never shown to users."
    },
    "extraction_error": {
      "type": "string",
      "default": "",
      "description": "Error message if extraction_status is failed or partial."
    },
    "total_entries": {
      "type": "integer",
      "default": 0,
      "description": "Total number of SirrManuscriptEntry records extracted from this book."
    },
    "notes": {
      "type": "string",
      "default": "",
      "description": "Admin notes about this SIRR manuscript."
    }
  },
  "required": [
    "sirr_book_id",
    "book_title",
    "extraction_status"
  ],
  "indexes": [
    {
      "name": "idx_sirr_book_id",
      "fields": [
        "sirr_book_id"
      ]
    },
    {
      "name": "idx_source",
      "fields": [
        "source"
      ]
    },
    {
      "name": "idx_extraction_status",
      "fields": [
        "extraction_status"
      ]
    },
    {
      "name": "idx_upload_date",
      "fields": [
        "upload_date"
      ]
    },
    {
      "name": "idx_status_upload_date",
      "fields": [
        "extraction_status",
        "upload_date"
      ]
    },
    {
      "name": "idx_last_processed_page",
      "fields": [
        "last_processed_page"
      ]
    }
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": true,
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}